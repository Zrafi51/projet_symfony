<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title|default('Projet Symfony') }}{% endblock %}</title>
    <link rel="icon" type="image/png" href="/assets/java/trans_bg.png">
    <link rel="stylesheet" href="/app.css">
    <link rel="stylesheet" href="/currency.css">
    {% for stylesheet in stylesheets|default([]) %}
        <link rel="stylesheet" href="{{ stylesheet }}">
    {% endfor %}
</head>
{% set currentPath = path|default('/') %}
{% set databaseError = databaseError|default(null) %}
{% set statusMessage = statusMessage|default(null) %}
{% set errorMessage = errorMessage|default(null) %}
{% set currentUser = current_user(currentUser|default(null)) %}
{% set photoUrl = currentUser.photo_display_url|default(currentUser.photo_url|default(''))|trim %}
{% set fullName = (currentUser.prenom|default('') ~ ' ' ~ currentUser.nom|default(''))|trim %}
{% set displayName = currentUser.display_name|default(fullName) %}
{% if displayName == '' %}
    {% set displayName = currentUser.email|default('Voyageur') %}
{% endif %}
{% set accountButtonName = currentUser.prenom|default('')|trim %}
{% if accountButtonName == '' %}
    {% set accountButtonName = currentUser.nom|default('')|trim %}
{% endif %}
{% if accountButtonName == '' %}
    {% set accountButtonName = displayName %}
{% endif %}
{% if '@' in accountButtonName %}
    {% set accountButtonName = accountButtonName|split('@')|first %}
{% endif %}
{% set userInitial = (currentUser.prenom|default(displayName)|slice(0, 1))|upper %}
{% set userRole = currentUser.role|default('USER')|upper %}
{% set isAdminUser = userRole == 'ADMIN' %}
{% set accountDashboardPath = isAdminUser ? '/admin/dashboard' : '/dashboard' %}
{% set accountProfilePath = isAdminUser ? '/admin/settings' : '/profile' %}
{% set accountProfileTitle = isAdminUser ? 'Parametres admin' : 'Gerer profil' %}
{% set accountProfileSubtitle = isAdminUser ? 'Securite et informations du compte' : 'Vos informations personnelles' %}
{% set accountDashboardTitle = isAdminUser ? 'Dashboard admin' : 'Dashboard' %}
{% set accountDashboardSubtitle = isAdminUser ? 'Piloter la plateforme' : 'Votre espace client' %}
<body>
    <div class="page-backdrop"></div>
    <div class="shell">
        <header class="site-header">
            <a class="brand" href="/">
                <span class="brand-logo-shell">
                    <img class="brand-logo brand-logo-animated" src="/assets/java/logo-animated.svg" alt="Logo anime EasyTravel du projet Java">
                </span>
                <span class="brand-copy">
                    <small>Logo anime de l'accueil Java</small>
                    <strong>Migre tel quel dans Symfony</strong>
                </span>
            </a>

            
            <div class="site-header-actions">
                <div class="header-pill">
                    <span class="status-dot status-dot-{{ currentPath starts with '/weather' ? 'weather' : 'default' }}"></span>
                    <span>{{ isAdminUser ? 'Session admin connectee' : 'Base de données active' }}</span>
                </div>
                {% include 'partials/currency-switcher.html.twig' with {currencySwitcherClass: 'currency-switcher-nav', currencySwitcherId: 'layoutCurrencySwitcher'} %}

                {% if currentUser %}
                    <div class="account-menu-wrapper" data-account-menu-wrapper>
                        <button
                            class="connexion-button site-login-button account-button account-button-logged-in"
                            type="button"
                            data-account-menu-button
                            aria-controls="siteAccountMenu"
                            aria-expanded="false"
                        >
                            <div class="account-button-content">
                                <div class="account-button-avatar">
                                    {% if photoUrl %}
                                        <img src="{{ photoUrl }}" alt="{{ displayName }}" class="account-avatar-image">
                                    {% else %}
                                        <span class="account-button-avatar-label">{{ userInitial }}</span>
                                    {% endif %}
                                </div>
                                <span class="account-button-name">{{ accountButtonName }}</span>
                                <span class="account-button-arrow">&#9662;</span>
                            </div>
                        </button>

                        <div class="navbar-account-menu" id="siteAccountMenu" data-account-menu hidden>
                            <div class="account-menu-header">
                                <div class="account-menu-header-avatar">
                                    {% if photoUrl %}
                                        <img src="{{ photoUrl }}" alt="{{ displayName }}" class="account-menu-avatar-image">
                                    {% else %}
                                        <span class="account-menu-header-avatar-label">{{ userInitial }}</span>
                                    {% endif %}
                                </div>
                                <div class="account-menu-header-text">
                                    <div class="account-menu-header-name">{{ displayName }}</div>
                                    <div class="account-menu-header-email">{{ currentUser.email|default('Compte utilisateur') }}</div>
                                </div>
                            </div>
                            <div class="account-menu-separator"></div>
                            <a href="{{ accountProfilePath }}" class="account-menu-item">
                                <div class="account-menu-icon-shell">
                                    <div class="account-menu-icon-shape account-menu-icon-profile">👤</div>
                                </div>
                                <div class="account-menu-item-labels">
                                    <div class="account-menu-title">{{ accountProfileTitle }}</div>
                                    <div class="account-menu-subtitle">{{ accountProfileSubtitle }}</div>
                                </div>
                                <span class="account-menu-item-chevron">→</span>
                            </a>
                            <a href="/weather" class="account-menu-item {{ currentPath starts with '/weather' ? 'menu-active' : '' }}">
                                <div class="account-menu-icon-shell">
                                    <div class="account-menu-icon-shape account-menu-icon-weather">🌤️</div>
                                </div>
                                <div class="account-menu-item-labels">
                                    <div class="account-menu-title">Météo</div>
                                    <div class="account-menu-subtitle">Prévisions météo mondiales</div>
                                </div>
                                <span class="account-menu-item-chevron">→</span>
                            </a>
                            <a href="/forum" class="account-menu-item">
                                <div class="account-menu-icon-shell">
                                    <div class="account-menu-icon-shape account-menu-icon-forum">💬</div>
                                </div>
                                <div class="account-menu-item-labels">
                                    <div class="account-menu-title">Forum</div>
                                    <div class="account-menu-subtitle">Discussions et echanges voyageurs</div>
                                </div>
                                <span class="account-menu-item-chevron">→</span>
                            </a>
                            <a href="{{ accountDashboardPath }}" class="account-menu-item">
                                <div class="account-menu-icon-shell">
                                    <div class="account-menu-icon-shape account-menu-icon-dashboard">📊</div>
                                </div>
                                <div class="account-menu-item-labels">
                                    <div class="account-menu-title">{{ accountDashboardTitle }}</div>
                                    <div class="account-menu-subtitle">{{ accountDashboardSubtitle }}</div>
                                </div>
                                <span class="account-menu-item-chevron">→</span>
                            </a>
                            <div class="account-menu-separator"></div>
                            <a href="/logout" class="account-menu-item account-menu-item-danger">
                                <div class="account-menu-icon-shell account-menu-icon-shell-danger">
                                    <div class="account-menu-icon-shape account-menu-icon-shape-danger account-menu-icon-logout">🚪</div>
                                </div>
                                <div class="account-menu-item-labels">
                                    <div class="account-menu-title account-menu-title-danger">Deconnexion</div>
                                    <div class="account-menu-subtitle account-menu-subtitle-danger">Fermer la session active</div>
                                </div>
                                <span class="account-menu-item-chevron">→</span>
                            </a>
                        </div>
                    </div>
                {% else %}
                    <a href="/login" class="connexion-button site-login-button">Connexion</a>
                {% endif %}
            </div>
        </header>

        {% if databaseError is not empty %}
            <div class="alert alert-error">{{ databaseError }}</div>
        {% endif %}

        {% if statusMessage is not empty %}
            <div class="alert alert-success">{{ statusMessage }}</div>
        {% endif %}

        {% if errorMessage is not empty %}
            <div class="alert alert-error">{{ errorMessage }}</div>
        {% endif %}

        <main class="page">
            {% block content %}
                {{ legacy_content|default('')|raw }}
            {% endblock %}
        </main>
    </div>
    <style>
        /* Status dot improvements for weather page */
        .status-dot-weather {
            background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
            box-shadow: 0 0 10px rgba(139, 92, 246, 0.5);
        }
        
        .status-dot-weather::after {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
            border-radius: 50%;
            z-index: -1;
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.7; transform: scale(1.1); }
        }
        
        /* Account menu improvements */
        .account-menu-icon-shape {
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }
        
        .account-menu-item.menu-active {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(124, 58, 237, 0.1) 100%);
            border-left: 3px solid #8B5CF6;
        }
        
        .account-menu-item.menu-active .account-menu-icon-shape {
            transform: scale(1.1);
        }
        
        .account-menu-item-chevron {
            transition: transform 0.3s ease;
        }
        
        .account-menu-item:hover .account-menu-item-chevron {
            transform: translateX(3px);
        }
    </style>
    <script src="/app.js"></script>
    <script src="/currency.js"></script>
</body>
</html>
