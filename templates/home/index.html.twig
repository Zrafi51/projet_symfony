                                <span class="home-destination-next-overlay"></span>
                                <span class="home-destination-next-play" aria-hidden="true"></span>
                            </div>
                            <div class="home-destination-next-copy">
                                <span>{{ destinationContinent }}</span>
                                <h3>{{ destinationName }}</h3>
                                <p>{{ destinationDescription|slice(0, 92) }}</p>
                                <a href="/destinations?search={{ destinationName|url_encode }}">
                                    Decouvrir <span aria-hidden="true">-></span>
                                </a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>

        <section class="home-services-next" data-service-section>
