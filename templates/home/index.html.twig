                                {% elseif service.icon == 'guide' %}
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15A2.25 2.25 0 0 0 21.75 17.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15A2.25 2.25 0 0 0 2.25 6.75v10.5A2.25 2.25 0 0 0 4.5 19.5Zm6-10.125a1.875 1.875 0 1 1-3.75 0 1.875 1.875 0 0 1 3.75 0Zm1.294 6.336a6.721 6.721 0 0 1-3.17.789 6.721 6.721 0 0 1-3.168-.789 3.376 3.376 0 0 1 6.338 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% elseif service.icon == 'experience' %}
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% elseif service.icon == 'support' %}
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% else %}
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </div>
                            <h3>{{ service.title }}</h3>
                            <p>{{ service.text }}</p>
                            <span class="home-service-next-line" aria-hidden="true"></span>
                        </article>
                    {% endfor %}
                </div>

                <div class="home-services-next-cta reveal-on-scroll" data-reveal-delay="560">
                    <a href="/chat?prompt=Je veux creer mon voyage avec EasyTravel" data-service-cta>
                        <span>Creer mon voyage -></span>
                    </a>
                </div>
            </div>
        </section>

        <section class="home-offers-next" data-offers-section>
            <span class="home-offers-next-aura" aria-hidden="true"></span>
            <div class="home-offers-next-inner">
                <div class="home-offers-next-head reveal-on-scroll">
                    <span>OFFRES LIMITEES</span>
                    <h2>Voyages speciaux</h2>
                    <p>Profitez de nos offres exclusives</p>
                </div>

                <div class="home-offers-next-grid">
                    {% for offer in offers %}
                        {% set offerPriceAmount = offer.price|replace({'EUR':'', 'TND':'', 'USD':'', ' ': '', ',': '.'}) %}
                        <article class="home-offer-next-card reveal-on-scroll" data-offer-card data-reveal-delay="{{ loop.index0 * 160 }}">
                            <div class="home-offer-next-media">
                                <img src="{{ offer.image }}" alt="{{ offer.title }}">
                                <span class="home-offer-next-media-shade"></span>
                                <span class="home-offer-next-badge">{{ offer.badge }}</span>
                            </div>
                            <div class="home-offer-next-body">
