{% set databaseError = databaseError|default(null) %}
{% set currentUser = current_user(currentUser|default(null)) %}
{% set photoUrl = currentUser.photo_display_url|default(currentUser.photo_url|default(''))|trim %}
{% set fullName = (currentUser.prenom|default('') ~ ' ' ~ currentUser.nom|default(''))|trim %}
{% set displayName = currentUser.display_name|default(fullName) %}
{% if displayName == '' %}
    {% set displayName = currentUser.email|default('Voyageur') %}
{% endif %}
{% set accountButtonName = currentUser.prenom|default('')|trim %}
{% if accountButtonName == '' %}
    {% set accountButtonName = currentUser.nom|default('')|trim %}
{% endif %}
{% if accountButtonName == '' %}
    {% set accountButtonName = displayName %}
{% endif %}
{% if '@' in accountButtonName %}
    {% set accountButtonName = accountButtonName|split('@')|first %}
{% endif %}
{% set userInitial = (currentUser.prenom|default(displayName)|slice(0, 1))|upper %}
{% set userRole = currentUser.role|default('USER')|upper %}
{% set isAdminUser = userRole == 'ADMIN' %}
{% set accountDashboardPath = isAdminUser ? '/admin/dashboard' : '/dashboard' %}
{% set accountProfilePath = isAdminUser ? '/admin/settings' : '/profile' %}
{% set accountProfileTitle = isAdminUser ? 'Parametres admin' : 'Gerer profil' %}
{% set accountProfileSubtitle = isAdminUser ? 'Securite et informations du compte' : 'Vos informations personnelles' %}
{% set accountDashboardTitle = isAdminUser ? 'Dashboard admin' : 'Dashboard' %}
{% set accountDashboardSubtitle = isAdminUser ? 'Piloter la plateforme' : 'Votre espace client' %}

{% set fallbackDestinations = [
    {nom: 'Paris', pays: 'France', continent: 'Europe', prix_base: 1890, description: 'La ville lumiere, entre art, gastronomie et promenades elegantes.'},
    {nom: 'Tokyo', pays: 'Japon', continent: 'Asie', prix_base: 2490, description: 'Tradition et modernite dans une capitale qui ne dort jamais.'},
    {nom: 'Bali', pays: 'Indonesie', continent: 'Asie', prix_base: 2290, description: 'Paradis tropical authentique, temples, rizieres et plages calmes.'},
    {nom: 'New York', pays: 'USA', continent: 'Amerique', prix_base: 2890, description: 'La ville qui ne dort jamais, version skyline et experiences premium.'},
    {nom: 'Marrakech', pays: 'Maroc', continent: 'Afrique', prix_base: 1690, description: 'Couleurs, palais, souks et deserts proches pour un voyage sensoriel.'},
    {nom: 'Islande', pays: 'Islande', continent: 'Europe', prix_base: 3190, description: 'Terre de feu et de glace, cascades, aurores et routes sauvages.'}
] %}
{% set homeDestinations = previewDestinations|default([]) is empty ? fallbackDestinations : previewDestinations|default([]) %}
{% set sponsorCards = homeSponsors|default([]) %}
{% set atmosphereCards = homeAtmospheres|default([]) %}
{% set services = [
    {icon: 'flight', title: 'Vols internationaux premium', text: 'Itineraires optimises et confort sur chaque trajet.'},
    {icon: 'hotel', title: 'Hotels 5 etoiles selectionnes', text: 'Adresses controlees pour dormir sans mauvaise surprise.'},
    {icon: 'guide', title: 'Guides locaux experts', text: 'Une vraie lecture du pays, pas seulement une visite.'},
    {icon: 'experience', title: 'Experiences authentiques', text: 'Moments rares, tables locales, ateliers et aventures.'},
    {icon: 'support', title: 'Assistance 24/7', text: 'Une equipe disponible avant, pendant et apres le voyage.'},
    {icon: 'concierge', title: 'Conciergerie dediee', text: 'Details, preferences et petits luxes bien prepares.'}
] %}
{% set offers = [
    {badge: 'Populaire', title: 'Escapade Romantique', place: 'Paris & Provence', days: '7 jours', price: '1 890 EUR', image: '/assets/java/9b4f03d821c26c149892eb9b646573bc.jpg'},
    {badge: 'Nouveau', title: 'Aventure Asiatique', place: 'Thailande & Vietnam', days: '14 jours', price: '2 490 EUR', image: '/assets/java/da89f34fb5595d60358fcefe64fc6659.jpg'},
    {badge: 'Exclusif', title: 'Safari Luxe', place: 'Kenya & Tanzanie', days: '10 jours', price: '4 990 EUR', image: '/assets/java/b98f59bef70929b9642bc88dd2a56f11.jpg'}
] %}
{% set fallbackMapPoints = [
    {city: 'Washington', country: 'Etats-Unis', continent: 'Amerique', package_name: 'Pack Capital Escape', duration: '5 jours / 4 nuits', price: '2490 EUR', original_price: '2890 EUR', image_path: '80281906250b49a80467292e998492eb.jpg', description: 'Une escapade urbaine premium entre monuments iconiques, musees et rooftops confidentiels.', best_period: 'Mars a juin', includes: 'Vol, hotel, city pass, transferts', highlight_1: 'Maison Blanche', highlight_2: 'Croisiere Potomac', highlight_3: 'Shopping signature', x_percent: 0.165, y_percent: 0.313, ai_score: 91, ai_recommended: 1},
    {city: 'Bogota', country: 'Colombie', continent: 'Amerique', package_name: 'Pack Andes Panorama', duration: '7 jours / 6 nuits', price: '1690 EUR', original_price: '1990 EUR', image_path: 'da89f34fb5595d60358fcefe64fc6659.jpg', description: 'Un pack vibrant entre art de rue, haute gastronomie et paysages andins.', best_period: 'Decembre a mars', includes: 'Vol, hotel boutique, guide local', highlight_1: 'La Candelaria', highlight_2: 'Monserrate', highlight_3: 'Atelier cafe', x_percent: 0.189, y_percent: 0.517, ai_score: 86, ai_recommended: 1},
    {city: 'Paris', country: 'France', continent: 'Europe', package_name: 'Pack City Lights', duration: '4 jours / 3 nuits', price: '1890 EUR', original_price: '2140 EUR', image_path: '3fddde5acc7047afabbb1d9dd69301cd.jpg', description: 'Paris avec elegance, entre adresses signatures et experiences romantiques.', best_period: 'Avril a octobre', includes: 'Hotel 4*, croisiere, transferts', highlight_1: 'Billets coupe-file', highlight_2: 'Diner Seine', highlight_3: 'Guide art de vivre', x_percent: 0.413, y_percent: 0.225, ai_score: 95, ai_recommended: 1},
    {city: 'Tokyo', country: 'Japon', continent: 'Asie', package_name: 'Pack Neo Tokyo', duration: '8 jours / 7 nuits', price: '2190 EUR', original_price: '2620 EUR', image_path: 'bac4bce325c9a10f6fb77f30682cc7fa.jpg', description: 'Une immersion entre modernite japonaise, temples et quartiers futuristes.', best_period: 'Mars a mai', includes: 'Vol, hotel central, JR pass', highlight_1: 'Shibuya et Asakusa', highlight_2: 'TeamLab inclus', highlight_3: 'Food tour', x_percent: 0.862, y_percent: 0.325, ai_score: 93, ai_recommended: 1},
    {city: 'Sydney', country: 'Australie', continent: 'Oceanie', package_name: 'Pack Harbour Signature', duration: '9 jours / 8 nuits', price: '3190 EUR', original_price: '3690 EUR', image_path: 'GettyImages-158525984-5b6df57dc9e77c005086b0ca.jpg', description: 'Un grand voyage lifestyle entre baie mythique, plages iconiques et soleil.', best_period: 'Septembre a novembre', includes: 'Vol, hotel vue baie, activites', highlight_1: 'Opera House', highlight_2: 'Bondi et Blue Mountains', highlight_3: 'Conciergerie', x_percent: 0.820, y_percent: 0.734, ai_score: 88, ai_recommended: 1}
] %}
{% set mapCards = homeMapPoints|default([]) is empty ? fallbackMapPoints : homeMapPoints|default([]) %}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title|default('EasyTravel - Accueil') }}</title>
    <link rel="icon" type="image/png" href="/assets/java/trans_bg.png">
    <link rel="stylesheet" href="/app.css">
    <link rel="stylesheet" href="/about.css">
    <link rel="stylesheet" href="/currency.css">
    <link rel="stylesheet" href="/home.css">
</head>
<body class="home-page-body">
    <div class="home-noise" aria-hidden="true"></div>

    <header class="about-navbar-shell" id="aboutNavbar">
        <div class="about-navbar">
            <div class="about-navbar-brand">
                <a href="/" class="about-logo-shell" aria-label="Retour a l accueil">
                    <canvas id="aboutLogoCanvas" width="200" height="60"></canvas>
                </a>
            </div>

            <nav class="about-navbar-links" aria-label="Navigation principale">
                <a href="/" class="about-nav-button about-nav-button-active">Accueil</a>
                <a href="/destinations" class="about-nav-button">Destinations</a>
                <a href="/about" class="about-nav-button">A propos</a>
                <a href="/contact" class="about-nav-button">Contact</a>
            </nav>

            <div class="about-navbar-actions">
                <button type="button" class="about-search-button" id="aboutSearchToggle" aria-label="Ouvrir la recherche">&#128269;</button>
                {% include 'partials/currency-switcher.html.twig' with {currencySwitcherClass: 'currency-switcher-nav', currencySwitcherId: 'homeCurrencySwitcher'} %}
            {% if currentUser %}
                <div class="account-menu-wrapper" data-account-menu-wrapper>
                    <button class="connexion-button account-button account-button-logged-in" type="button" data-account-menu-button aria-controls="homeAccountMenu" aria-expanded="false">
                        <div class="account-button-content">
                            <div class="account-button-avatar">
                                {% if photoUrl %}
                                    <img src="{{ photoUrl }}" alt="{{ displayName }}" class="account-avatar-image">
                                {% else %}
                                    <span class="account-button-avatar-label">{{ userInitial }}</span>
                                {% endif %}
                            </div>
                            <span class="account-button-name">{{ accountButtonName }}</span>
                            <span class="account-button-arrow">&#9662;</span>
                        </div>
                    </button>
                    <div class="navbar-account-menu" id="homeAccountMenu" data-account-menu hidden>
                        <div class="account-menu-header">
                            <div class="account-menu-header-avatar">
                                {% if photoUrl %}
                                    <img src="{{ photoUrl }}" alt="{{ displayName }}" class="account-menu-avatar-image">
                                {% else %}
                                    <span class="account-menu-header-avatar-label">{{ userInitial }}</span>
                                {% endif %}
                            </div>
                            <div class="account-menu-header-text">
                                <div class="account-menu-header-name">{{ displayName }}</div>
                                <div class="account-menu-header-email">{{ currentUser.email|default('Compte utilisateur') }}</div>
                            </div>
                        </div>
                        <div class="account-menu-separator"></div>
                        <a href="{{ accountProfilePath }}" class="account-menu-item">
                            <div class="account-menu-icon-shell"><div class="account-menu-icon-shape account-menu-icon-profile"></div></div>
                            <div class="account-menu-item-labels">
                                <div class="account-menu-title">{{ accountProfileTitle }}</div>
                                <div class="account-menu-subtitle">{{ accountProfileSubtitle }}</div>
                            </div>
                            <span class="account-menu-item-chevron">&#8250;</span>
                        </a>
                        <a href="/forum" class="account-menu-item">
                            <div class="account-menu-icon-shell"><div class="account-menu-icon-shape account-menu-icon-forum"></div></div>
                            <div class="account-menu-item-labels">
                                <div class="account-menu-title">Forum</div>
                                <div class="account-menu-subtitle">Discussions voyageurs</div>
                            </div>
                            <span class="account-menu-item-chevron">&#8250;</span>
                        </a>
                        <a href="{{ accountDashboardPath }}" class="account-menu-item">
                            <div class="account-menu-icon-shell"><div class="account-menu-icon-shape account-menu-icon-dashboard"></div></div>
                            <div class="account-menu-item-labels">
                                <div class="account-menu-title">{{ accountDashboardTitle }}</div>
                                <div class="account-menu-subtitle">{{ accountDashboardSubtitle }}</div>
                            </div>
                            <span class="account-menu-item-chevron">&#8250;</span>
                        </a>
                        <div class="account-menu-separator"></div>
                        <a href="/logout" class="account-menu-item account-menu-item-danger">
                            <div class="account-menu-icon-shell account-menu-icon-shell-danger"><div class="account-menu-icon-shape account-menu-icon-shape-danger account-menu-icon-logout"></div></div>
                            <div class="account-menu-item-labels">
                                <div class="account-menu-title account-menu-title-danger">Deconnexion</div>
                                <div class="account-menu-subtitle account-menu-subtitle-danger">Fermer la session active</div>
                            </div>
                            <span class="account-menu-item-chevron">&#8250;</span>
                        </a>
                    </div>
                </div>
            {% else %}
                <a class="connexion-button" href="/login">Connexion</a>
            {% endif %}
            </div>
        </div>
    </header>

    <div class="about-search-overlay" id="aboutSearchOverlay" style="display: none;" aria-hidden="true">
        <div class="about-search-panel" id="aboutSearchPanel" role="dialog" aria-modal="true" aria-labelledby="aboutSearchTitle">
            <div class="about-search-header">
                <div>
                    <h2 id="aboutSearchTitle">Rechercher votre voyage</h2>
                    <p>Retrouvez une destination, une date et le nombre de voyageurs en quelques clics.</p>
                </div>
                <button type="button" class="about-search-close" id="aboutSearchClose" aria-label="Fermer la recherche">&#10005;</button>
            </div>

            <div class="about-search-grid">
                <label class="about-search-field">
                    <span>Destination</span>
                    <input type="search" id="aboutSearchDestination" placeholder="Ou voulez-vous aller ?">
                </label>
                <label class="about-search-field">
                    <span>Date</span>
                    <input type="date" id="aboutSearchDate">
                </label>
                <label class="about-search-field">
                    <span>Voyageurs</span>
                    <select id="aboutSearchTravelers">
                        <option value="1">1</option>
                        <option value="2" selected>2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                        <option value="5">5</option>
                        <option value="6">6</option>
                    </select>
                </label>
            </div>

            <div class="about-search-popular">
                <span>Destinations populaires :</span>
                <button type="button" class="about-search-chip" data-destination="Bali">Bali</button>
                <button type="button" class="about-search-chip" data-destination="Maldives">Maldives</button>
                <button type="button" class="about-search-chip" data-destination="Tokyo">Tokyo</button>
                <button type="button" class="about-search-chip" data-destination="Santorini">Santorini</button>
            </div>

            <p class="about-search-message" id="aboutSearchMessage"></p>
            <button type="button" class="about-search-submit" id="aboutSearchSubmit">&#128269; Rechercher mon voyage</button>
        </div>
    </div>

    {% if databaseError is not empty %}
        <div class="home-alert" role="alert">{{ databaseError }}</div>
    {% endif %}

    <main class="home-main">
        <section class="home-hero" id="accueil">
            <video class="home-hero-video" autoplay muted loop playsinline poster="/assets/java/homepage-hero-video-poster.png" data-home-video-list="/assets/java/M.mp4|/assets/java/Waterfall view.mp4">
                <source src="/assets/java/M.mp4" type="video/mp4">
            </video>
            <div class="home-hero-shade"></div>
            <div class="home-hero-orbit" aria-hidden="true"></div>
            <div class="home-hero-video-controls" aria-label="Controles video hero">
                <button type="button" class="home-hero-video-control home-hero-video-control-play is-playing" data-home-video-toggle aria-label="Lire ou mettre en pause la video">
                    <span class="home-hero-control-play"></span>
                    <span class="home-hero-control-pause"></span>
                </button>
                <button type="button" class="home-hero-video-control" data-home-video-switch aria-label="Changer la video">
                    <span class="home-hero-control-refresh"></span>
                </button>
            </div>
            <div class="home-hero-content reveal-on-scroll">
                <h1>Decouvrez le monde <span>avec elegance</span></h1>
                <p class="home-hero-lead">Des destinations soigneusement selectionnees pour des souvenirs inoubliables.</p>
                <div class="home-hero-actions">
                    <a class="home-primary-button" href="/destinations">Explorer les destinations</a>
                    <button class="home-ghost-button" type="button" data-open-search>Nos offres</button>
                </div>
            </div>
            <article class="home-preview-card reveal-on-scroll" data-reveal-delay="160">
                <div class="home-preview-media">
                    <video autoplay muted loop playsinline poster="/assets/java/bali-1-1679062958.profileImage.2x-1536x884.webp">
                        <source src="/assets/java/Luke Cameron.mp4" type="video/mp4">
                    </video>
                    <span class="home-preview-badge">Populaire</span>
                    <span class="home-preview-rating">4.8 (124 avis)</span>
                </div>
                <div class="home-preview-copy">
                    <h3>Bali, Indonesie</h3>
                    <p>8 jours / 7 nuits</p>
                    <div class="home-preview-price-row">
                        <div>
                            <strong data-money data-money-base="EUR" data-money-amount="1890">1 890 EUR</strong>
                            <small data-money data-money-base="EUR" data-money-amount="2290">2 290 EUR</small>
                        </div>
                        <a href="/destinations">Voir</a>
                    </div>
                </div>
            </article>
        </section>

        <section class="home-sponsors-section reveal-on-scroll" aria-label="Partenaires EasyTravel">
            <div class="home-sponsors-bg-grid" aria-hidden="true"></div>
            <span class="home-sponsor-orb home-sponsor-orb-blue" aria-hidden="true"></span>
            <span class="home-sponsor-orb home-sponsor-orb-pink" aria-hidden="true"></span>
            <span class="home-sponsor-orb home-sponsor-orb-cyan" aria-hidden="true"></span>
            <div class="home-sponsor-particles" aria-hidden="true">
                {% for particle in 1..20 %}
                    <span></span>
                {% endfor %}
            </div>

            <div class="home-sponsors-inner">
                <div class="home-sponsors-heading">
                    <span>Partenaires premium</span>
                    <h2>Ils nous font <strong>confiance</strong></h2>
                    <div class="home-sponsors-divider" aria-hidden="true"></div>
                    <p>Les logos affiches ici viennent uniquement du CRUD admin Sponsors Home.</p>
                    {% if isAdminUser %}
                        <a href="/admin/dashboard?section=sponsors" class="home-sponsors-admin-link">Gerer les sponsors</a>
                    {% endif %}
                </div>

                <div class="home-sponsor-marquee">
                    <div class="home-sponsor-fade home-sponsor-fade-left" aria-hidden="true"></div>
                    <div class="home-sponsor-fade home-sponsor-fade-right" aria-hidden="true"></div>
                    <div class="home-sponsor-track {{ sponsorCards is empty ? 'home-sponsor-track-empty' : '' }}">
                        {% if sponsorCards is empty %}
                            <article class="home-sponsor-empty-card">
                                <span>Admin</span>
                                <strong>Aucun sponsor actif</strong>
                                <small>Ajoutez un logo depuis le dashboard admin pour l afficher ici.</small>
                                {% if isAdminUser %}
                                    <a href="/admin/dashboard?section=sponsors">Ouvrir les sponsors</a>
                                {% endif %}
                            </article>
                        {% else %}
                            {% for sponsor in sponsorCards %}
                                {% set sponsorName = sponsor.nom|default('Sponsor')|trim %}
                                {% set sponsorType = sponsor.type|default('Partenaire')|trim %}
                                {% set sponsorLogo = sponsor.logo_display_url|default(sponsor.logo_url|default(''))|trim %}
                                {% set sponsorUrl = sponsor.site_web|default('#')|trim %}
                                {% set colorIndex = loop.index0 % 7 %}
                                {% set cardContent %}
                                    <span class="home-sponsor-card-glow"></span>
                                    <span class="home-sponsor-card-glow home-sponsor-card-glow-soft"></span>
                                    <span class="home-sponsor-shine home-sponsor-shine-x"></span>
                                    <span class="home-sponsor-shine home-sponsor-shine-y"></span>
                                    <div class="home-sponsor-logo">
                                        {% if sponsorLogo is not empty %}
                                            <img src="{{ sponsorLogo }}" alt="{{ sponsorName is not empty ? sponsorName : 'Sponsor' }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';">
                                            <span style="display:none;">{{ (sponsorName is not empty ? sponsorName : 'S')|slice(0, 1)|upper }}</span>
                                        {% else %}
                                            <span>{{ (sponsorName is not empty ? sponsorName : 'S')|slice(0, 1)|upper }}</span>
                                        {% endif %}
                                    </div>
                                    <strong>{{ sponsorName is not empty ? sponsorName : 'Sponsor' }}</strong>
                                    <small>{{ sponsorType is not empty ? sponsorType : 'Partenaire' }}</small>
                                {% endset %}
                                {% if sponsorUrl is not empty and sponsorUrl != '#' %}
                                    <a class="home-sponsor-card home-sponsor-card-{{ colorIndex }}" href="{{ sponsorUrl }}" target="_blank" rel="noopener">
                                        {{ cardContent|raw }}
                                    </a>
                                {% else %}
                                    <article class="home-sponsor-card home-sponsor-card-{{ colorIndex }}">
                                        {{ cardContent|raw }}
                                    </article>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                <div class="home-sponsor-stats">
                    <article class="home-sponsor-stat home-sponsor-stat-cyan">
                        <span>{{ sponsorCards|length }}</span>
                        <strong>Partenaires</strong>
                    </article>
                    <article class="home-sponsor-stat home-sponsor-stat-blue">
                        <span>150+</span>
                        <strong>Pays</strong>
                    </article>
                    <article class="home-sponsor-stat home-sponsor-stat-purple">
                        <span>1M+</span>
                        <strong>Reservations</strong>
                    </article>
                    <article class="home-sponsor-stat home-sponsor-stat-pink">
                        <span>4.9</span>
                        <strong>Satisfaction</strong>
                    </article>
                </div>
            </div>
        </section>

        <section class="home-atmosphere-next" data-atmosphere-section aria-label="Ambiances de voyage">
            <div class="home-atmosphere-next-sticky">
                <div class="home-atmosphere-next-head reveal-on-scroll">
                    <h2>Choisissez votre</h2>
                    <h2>ambiance</h2>
                    <p>Les cartes sont controlees depuis le CRUD admin Atmospheres et gardent le style video du projet Next.js.</p>
                    {% if isAdminUser %}
                        <a href="/admin/dashboard?section=atmospheres">Gerer les ambiances</a>
                    {% endif %}
                </div>

                <div class="home-atmosphere-progress" aria-hidden="true">
                    <span data-atmosphere-progress></span>
                </div>

                <div class="home-atmosphere-next-track" data-atmosphere-track>
                    {% if atmosphereCards is empty %}
                        <article class="home-atmosphere-empty-card reveal-on-scroll">
                            <span>Atmospheres admin</span>
                            <h3>Aucune ambiance active</h3>
                            <p>Activez ou creez une atmosphere dans le dashboard admin pour alimenter cette section.</p>
                            {% if isAdminUser %}
                                <a href="/admin/dashboard?section=atmospheres">Gerer les ambiances</a>
                            {% endif %}
                        </article>
                    {% else %}
                    {% for card in atmosphereCards %}
                        {% set rawTitle = card.title|default(card.atmosphere_type|default('ATMOSPHERE'))|trim %}
                        {% set cardTitle = rawTitle is not empty ? rawTitle|upper : 'ATMOSPHERE' %}
                        {% set cardType = card.atmosphere_type|default(cardTitle)|upper %}
                        {% set rawVideo = card.video_path|default(card.video|default(''))|trim %}
                        {% set cardVideo = rawVideo is not empty ? (rawVideo starts with '/' or rawVideo starts with 'http' ? rawVideo : '/assets/java/' ~ rawVideo) : '' %}
                        {% set defaultKicker = cardType == 'SAFARI' ? 'AVENTURE SAUVAGE' : (cardType == 'URBAIN' ? 'VILLES DU MONDE' : (cardType == 'PLAGE' ? 'PARADIS TROPICAL' : (cardType == 'MONTAGNE' ? 'SOMMETS MAJESTUEUX' : 'VOYAGE SIGNATURE'))) %}
                        {% set cardKicker = card.kicker|default(defaultKicker)|trim %}
                        {% set cardDescription = card.description|default('Ambiance EasyTravel synchronisee avec le dashboard admin.')|trim %}
                        {% set exploreUrl = cardVideo is not empty ? '/destinations?hero_video=' ~ cardVideo|url_encode : '/destinations' %}
                        <article class="home-atmosphere-next-card reveal-on-scroll" data-reveal-delay="{{ loop.index0 * 90 }}">
                            <div class="home-atmosphere-next-media">
                                {% if cardVideo is not empty %}
                                    <video autoplay muted loop playsinline>
                                        <source src="{{ cardVideo }}" type="video/mp4">
                                    </video>
                                {% endif %}
                                <span class="home-atmosphere-next-overlay"></span>
                            </div>
                            <div class="home-atmosphere-next-copy">
                                <span>{{ cardKicker|upper }}</span>
                                <h3>{{ cardTitle }}</h3>
                                <p>{{ cardDescription|slice(0, 120) }}</p>
                                <a href="{{ exploreUrl }}">Explorer</a>
                            </div>
                        </article>
                    {% endfor %}
                    {% endif %}
                </div>
            </div>
        </section>

        <section class="home-destinations-next" data-destinations-section>
            <div class="home-destinations-next-inner">
                <div class="home-destinations-next-head reveal-on-scroll">
                    <h2>Destinations populaires</h2>
                    <p>Explorez nos destinations les plus prisees</p>
                    {% if isAdminUser %}
                        <a href="/admin/dashboard?section=destinations">Gerer les destinations vedettes</a>
                    {% endif %}
                </div>

                <div class="home-destinations-next-grid">
                    {% for destination in homeDestinations|slice(0, 6) %}
                        {% set destinationName = destination.destination_name|default(destination.nom|default('Destination'))|trim %}
                        {% set destinationCountry = destination.country|default(destination.pays|default(''))|trim %}
                        {% set destinationContinent = destination.continent|default('Monde')|trim %}
                        {% set destinationDescription = destination.description|default('Une destination signature selectionnee avec la logique Java et synchronisee avec Symfony.')|trim %}
                        {% set text = (destinationName ~ ' ' ~ destinationCountry ~ ' ' ~ destinationContinent)|lower %}
                        {% set image = '/assets/java/bac4bce325c9a10f6fb77f30682cc7fa.jpg' %}
                        {% set inferredVideo = '/assets/java/Luke Cameron.mp4' %}
                        {% if 'paris' in text or 'france' in text %}
                            {% set image = '/assets/java/3fddde5acc7047afabbb1d9dd69301cd.jpg' %}
                            {% set inferredVideo = '/assets/java/An Qiang.mp4' %}
                        {% elseif 'tokyo' in text or 'japon' in text %}
                            {% set image = '/assets/java/bac4bce325c9a10f6fb77f30682cc7fa.jpg' %}
                            {% set inferredVideo = '/assets/java/M.mp4' %}
                        {% elseif 'bali' in text or 'indonesie' in text %}
                            {% set image = '/assets/java/bali-1-1679062958.profileImage.2x-1536x884.webp' %}
                            {% set inferredVideo = '/assets/java/Luke Cameron.mp4' %}
                        {% elseif 'new york' in text or 'usa' in text or 'amerique' in text %}
                            {% set image = '/assets/java/80281906250b49a80467292e998492eb.jpg' %}
                            {% set inferredVideo = '/assets/java/Marina.NewyorkCity.mp4' %}
                        {% elseif 'marrakech' in text or 'maroc' in text or 'afrique' in text %}
                            {% set image = '/assets/java/b98f59bef70929b9642bc88dd2a56f11.jpg' %}
                            {% set inferredVideo = '/assets/java/Sky2Tours.mp4' %}
                        {% elseif 'islande' in text %}
                            {% set image = '/assets/java/GettyImages-158525984-5b6df57dc9e77c005086b0ca.jpg' %}
                            {% set inferredVideo = '/assets/java/A beautifull Sceneary.mp4' %}
                        {% endif %}
                        {% set rawVideo = destination.video_path|default('')|trim %}
                        {% set destinationVideo = rawVideo is not empty ? (rawVideo starts with '/' or rawVideo starts with 'http' ? rawVideo : '/assets/java/' ~ rawVideo) : inferredVideo %}
                        <article class="home-destination-next-card home-destination-next-card-{{ loop.index0 % 3 }} reveal-on-scroll" data-reveal-delay="{{ loop.index0 * 110 }}">
