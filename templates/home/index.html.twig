        <section class="home-java-map-section" data-map-next>
            <span class="home-java-map-backdrop" aria-hidden="true"></span>
            <div class="home-java-map-content">
                <div class="home-java-map-heading reveal-on-scroll">
                    <span>MAP DESTINATIONS</span>
                    <h2>Choisissez un point, voyez le pack</h2>
                    <p>Survolez un repere sur la carte pour afficher le pack correspondant.</p>
                    {% if isAdminUser %}
                        <a href="/admin/dashboard?section=map">Gerer la carte</a>
                    {% endif %}
                </div>

                <div class="home-java-map-visual reveal-on-scroll" data-reveal-delay="140">
                    <span class="home-java-map-glow" aria-hidden="true"></span>
                    <div class="home-java-map-canvas" data-map-next-layer aria-label="Carte interactive des destinations">
                        <img class="home-java-map-world" src="/assets/java/Flag-map_of_the_world_(2018).png" alt="Carte du monde">

                        {% for point in mapCards %}
                            {% set xValue = point.x_percent|default(point.x|default(0.5)) %}
                            {% set yValue = point.y_percent|default(point.y|default(0.5)) %}
                            {% set xPercent = xValue > 1 ? xValue : xValue * 100 %}
                            {% set yPercent = yValue > 1 ? yValue : yValue * 100 %}
                            {% set rawImage = point.image_path|default(point.image|default(''))|trim %}
                            {% set mapImage = rawImage is not empty ? (rawImage starts with '/' or rawImage starts with 'http' ? rawImage : ('/' in rawImage ? '/' ~ rawImage : '/assets/java/' ~ rawImage)) : '/assets/java/bac4bce325c9a10f6fb77f30682cc7fa.jpg' %}
                            {% set pointCity = point.city|default('Destination')|trim %}
                            {% set pointCountry = point.country|default('Monde')|trim %}
                            {% set pointTrip = point.package_name|default(point.trip|default('Package signature'))|trim %}
                            {% set pointDuration = point.duration|default('7 jours / 6 nuits')|trim %}
                            {% set pointDescription = point.description|default('Destination synchronisee avec la carte interactive EasyTravel.')|trim %}
                            {% set pointPrice = point.price|default('1490 EUR')|trim %}
                            {% set pointPriceAmount = pointPrice|replace({'EUR':'', 'TND':'', 'USD':'', ' ': '', ',': '.'}) %}
                            {% set pointOldPrice = point.original_price|default('')|trim %}
                            {% set pointOldPriceAmount = pointOldPrice|replace({'EUR':'', 'TND':'', 'USD':'', ' ': '', ',': '.'}) %}
                            <button
                                class="home-java-map-hotspot"
                                type="button"
                                style="--x: {{ xPercent }}%; --y: {{ yPercent }}%; --pin-delay: {{ loop.index0 * 90 }}ms;"
                                data-map-next-pin
                                data-map-next-city="{{ pointCity }}"
                                data-map-next-country="{{ pointCountry }}"
                                data-map-next-trip="{{ pointTrip }}"
                                data-map-next-duration="{{ pointDuration }}"
                                data-map-next-price="{{ pointPrice }}"
                                data-map-next-price-amount="{{ pointPriceAmount }}"
                                data-map-next-old-price="{{ pointOldPrice }}"
                                data-map-next-old-price-amount="{{ pointOldPriceAmount }}"
                                data-map-next-description="{{ pointDescription }}"
                                data-map-next-period="{{ point.best_period|default('Toute l annee') }}"
                                data-map-next-includes="{{ point.includes|default('Vol, hotel, guide') }}"
                                data-map-next-highlight-one="{{ point.highlight_1|default('Experience signature') }}"
                                data-map-next-highlight-two="{{ point.highlight_2|default('Budget bien calibre') }}"
                                data-map-next-highlight-three="{{ point.highlight_3|default('Suggestion IA') }}"
                                data-map-next-image="{{ mapImage }}"
                                data-map-next-href="/destinations?search={{ pointCity|url_encode }}"
                                aria-label="Voir {{ pointCity }}"
                            >
                                <span class="home-java-map-hotspot-glow"></span>
                                <span class="home-java-map-hotspot-ring"></span>
                                <span class="home-java-map-hotspot-base"></span>
                                <span class="home-java-map-hotspot-core"></span>
                            </button>
                        {% endfor %}

                        <article class="home-java-map-hover" id="homeMapNextHover" aria-hidden="true">
                            <div class="home-java-map-hover-media">
                                <img src="/assets/java/bac4bce325c9a10f6fb77f30682cc7fa.jpg" alt="" id="homeMapNextHoverImage">
                                <span>PACK DISPONIBLE</span>
                            </div>
                            <div class="home-java-map-hover-body">
                                <span id="homeMapNextHoverTrip">PACK SIGNATURE</span>
                                <h3 id="homeMapNextHoverCity">Destination</h3>
                                <p id="homeMapNextHoverCountry">Monde - depart rapide</p>
                                <div class="home-java-map-hover-tags">
                                    <strong id="homeMapNextHoverDuration">7 jours / 6 nuits</strong>
                                    <strong>Vol + hotel</strong>
                                </div>
                                <div class="home-java-map-hover-divider"></div>
                                <small>A partir de</small>
                                <b id="homeMapNextHoverPrice" data-money data-money-base="EUR" data-money-amount="1490">1490 EUR</b>
                                <button type="button" data-map-next-hover-detail>Details</button>
                            </div>
                        </article>
                    </div>
                </div>

                {% set firstPoint = mapCards[0] %}
                {% set firstRawImage = firstPoint.image_path|default(firstPoint.image|default(''))|trim %}
                {% set firstImage = firstRawImage is not empty ? (firstRawImage starts with '/' or firstRawImage starts with 'http' ? firstRawImage : ('/' in firstRawImage ? '/' ~ firstRawImage : '/assets/java/' ~ firstRawImage)) : '/assets/java/bac4bce325c9a10f6fb77f30682cc7fa.jpg' %}
                {% set firstPrice = firstPoint.price|default('1490 EUR') %}
                {% set firstPriceAmount = firstPrice|replace({'EUR':'', 'TND':'', 'USD':'', ' ': '', ',': '.'}) %}
                {% set firstOldPrice = firstPoint.original_price|default('') %}
                {% set firstOldPriceAmount = firstOldPrice|replace({'EUR':'', 'TND':'', 'USD':'', ' ': '', ',': '.'}) %}
                <div class="home-java-map-detail-host" id="homeMapNextDetailHost">
                    <article class="home-java-map-detail" id="homeMapNextDetail" aria-live="polite">
                        <div class="home-java-map-detail-media">
                            <img src="{{ firstImage }}" alt="{{ firstPoint.city|default('Destination') }}" id="homeMapNextImage">
                            <span id="homeMapNextTrip">{{ firstPoint.package_name|default(firstPoint.trip|default('Package signature'))|upper }}</span>
                            <button type="button" data-map-next-close>Fermer</button>
                            <div>
                                <h3 id="homeMapNextCity">{{ firstPoint.city|default('Destination') }}</h3>
                                <p id="homeMapNextCountry">{{ firstPoint.country|default('Monde') }} - experience complete</p>
                            </div>
                        </div>
                        <div class="home-java-map-detail-body">
                            <p id="homeMapNextDescription">{{ firstPoint.description|default('Destination synchronisee avec la carte interactive EasyTravel.') }}</p>
                            <div class="home-java-map-detail-chips">
                                <span id="homeMapNextDuration">{{ firstPoint.duration|default('7 jours / 6 nuits') }}</span>
                                <span id="homeMapNextPeriod">Meilleure periode: {{ firstPoint.best_period|default('Toute l annee') }}</span>
                                <span id="homeMapNextIncludes">{{ firstPoint.includes|default('Vol, hotel, guide') }}</span>
                            </div>
                            <div class="home-java-map-highlights">
                                <h4>Points forts du pack</h4>
                                <p id="homeMapNextHighlightOne">- {{ firstPoint.highlight_1|default('Experience signature') }}</p>
                                <p id="homeMapNextHighlightTwo">- {{ firstPoint.highlight_2|default('Budget bien calibre') }}</p>
                                <p id="homeMapNextHighlightThree">- {{ firstPoint.highlight_3|default('Suggestion IA') }}</p>
                            </div>
                            <div class="home-java-map-detail-footer">
                                <div>
                                    <small>Tarif pack</small>
                                    <strong id="homeMapNextPrice" data-money data-money-base="EUR" data-money-amount="{{ firstPriceAmount }}">{{ firstPrice }}</strong>
                                    <del id="homeMapNextOldPrice" data-money data-money-base="EUR" data-money-amount="{{ firstOldPriceAmount }}">{{ firstOldPrice }}</del>
                                </div>
                                <a href="/destinations" id="homeMapNextLink">Je veux ce pack</a>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        {% set journeySteps = [
            {phase: '01', title: 'Le Rêve', desc: "Tout commence par une étincelle, une envie d'ailleurs", icon: '✨', color: '#cfb07a'},
            {phase: '02', title: 'La Préparation', desc: 'Nous créons votre voyage sur mesure, chaque détail compte', icon: '🗺️', color: '#F4A261'},
            {phase: '03', title: 'Le Départ', desc: "L'aventure commence, le monde vous attend", icon: '✈️', color: '#E76F51'},
            {phase: '04', title: "L'Expérience", desc: 'Vivez des moments authentiques qui transforment', icon: '🌍', color: '#2A9D8F'},
            {phase: '05', title: 'Le Souvenir', desc: 'Des mémoires gravées à jamais dans votre cœur', icon: '💫', color: '#cfb07a'}
        ] %}
        <section class="home-journey-next" data-journey-next>
            <div class="home-journey-next-inner">
                <div class="home-journey-next-head reveal-on-scroll">
                    <span>VOTRE PARCOURS</span>
                    <h2>Votre Voyage,<br><em>Étape par Étape</em></h2>
                    <p>De l inspiration à la transformation, découvrez comment nous créons votre aventure unique</p>
                </div>

                <div class="home-journey-next-timeline" aria-label="Votre parcours EasyTravel">
                    <div class="home-journey-next-track" aria-hidden="true">
                        <div data-journey-progress></div>
                    </div>
                    <div class="home-journey-next-stack">
                    {% for step in journeySteps %}
                        <article
                            class="home-journey-next-step {{ loop.index is odd ? 'is-left' : 'is-right' }}"
                            id="step-{{ loop.index0 }}"
                            data-journey-step
                            data-journey-direction="{{ loop.index is odd ? '-1' : '1' }}"
                            style="--step-color: {{ step.color }};"
                        >
                            <div class="home-journey-next-content">
                                <div class="home-journey-next-card">
                                    <span>PHASE {{ step.phase }}</span>
                                    <h3>{{ step.title }}</h3>
                                    <p>{{ step.desc }}</p>
                                </div>
                            </div>
                            <div class="home-journey-next-icon timeline-icon" data-journey-icon style="background-color: {{ step.color }};">
                                {{ step.icon }}
                            </div>
                            <div class="home-journey-next-spacer" aria-hidden="true"></div>
                        </article>
                    {% endfor %}
                    </div>
                </div>
            </div>
        </section>
