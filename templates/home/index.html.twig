                                {% if service.icon == 'flight' %}
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 12 3.269 3.126A59.768 59.768 0 0 1 21.485 12 59.77 59.77 0 0 1 3.27 20.876L6 12Zm0 0h7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% elseif service.icon == 'hotel' %}
