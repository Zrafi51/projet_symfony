{% extends 'about-layout.html.twig' %}

{% block extra_head %}
    <link rel="stylesheet" href="/destinations.css">
{% endblock %}

{% block content %}
{% set visibleCount = '%02d'|format(destinations|length) %}
{% set topDestination = destinations|first %}
{% set topQualityScore = topDestination.quality_score|default(0) %}
{% set interestOptions = [
    {name: 'Plage', icon: '&#127958;'},
    {name: 'Aventure', icon: '&#9968;'},
    {name: 'Culture', icon: '&#127917;'},
    {name: 'Nature', icon: '&#127807;'},
    {name: 'Gastronomie', icon: '&#127869;'},
    {name: 'Detente', icon: '&#129496;'},
    {name: 'Shopping', icon: '&#128717;'}
] %}
<section
    class="destinations-page"
    data-destinations-page
    data-flask-enabled="{{ destinationFlaskAvailable|default(false) ? '1' : '0' }}"
    data-recommendation-endpoint="{{ destinationRecommendationEndpoint|default('/destinations/recommendations')|e('html_attr') }}"
    data-package-details-endpoint="{{ destinationPackageDetailsEndpoint|default('/destinations/package-details')|e('html_attr') }}"
    data-initial-search="{{ destinationInitialFilters.search|default('')|e('html_attr') }}"
    data-initial-continent="{{ destinationInitialFilters.continent|default('')|e('html_attr') }}"
    data-initial-budget-min="{{ destinationInitialFilters.budget_min|default(0) }}"
    data-initial-budget-max="{{ destinationInitialFilters.budget_max|default(0) }}"
    data-initial-departure="{{ destinationInitialFilters.departure|default('')|e('html_attr') }}"
    data-initial-return="{{ destinationInitialFilters.return|default('')|e('html_attr') }}"
    data-initial-travel-type="{{ destinationInitialFilters.travel_type|default('Tous les profils')|e('html_attr') }}"
    data-initial-adults="{{ destinationInitialFilters.adults|default(2) }}"
    data-initial-children="{{ destinationInitialFilters.children|default(0) }}"
    data-favorite-endpoint="{{ destinationFavoriteEndpoint|default('/favorites/toggle')|e('html_attr') }}"
    data-favorite-keys="{{ destinationFavoriteKeys|default([])|json_encode|e('html_attr') }}"
    data-is-authenticated="{{ currentUser.email|default('') ? '1' : '0' }}"
>
    <section class="destinations-hero about-scroll-reveal about-scroll-reveal-hero" data-scroll-reveal>
        <video class="destinations-hero-video" autoplay muted loop playsinline poster="/assets/java/homepage-hero-video-poster.png">
            <source src="{{ destinationHeroVideo|default('/assets/java/Sky2Tours.mp4') }}" type="video/mp4">
        </video>
        <div class="destinations-hero-overlay"></div>
        <div class="destinations-hero-content">
            <p class="destinations-hero-kicker">Collections Signature</p>
            <h1 class="destinations-hero-title">Nos Destinations</h1>
            <p class="destinations-hero-copy">Explorez les plus belles destinations du monde, soigneusement selectionnees pour vous, avec la meme ambiance premium, la meme logique de filtres et la meme experience immersive que le projet Java.</p>
            <div class="destinations-hero-actions">
                <a href="#destinationsFilters" class="destinations-hero-button">Trouver mon voyage</a>
                <a href="#destinationsGrid" class="destinations-hero-button destinations-hero-button-secondary">Voir les packs</a>
            </div>
        </div>
    </section>

    <section class="destinations-content">
        <div class="destinations-filters-shell about-scroll-reveal about-scroll-reveal-left" data-scroll-reveal id="destinationsFilters">
            <span class="destinations-filters-glow destinations-filters-glow-top"></span>
            <span class="destinations-filters-glow destinations-filters-glow-bottom"></span>

            <div class="destinations-filters-card">
                <input type="hidden" id="destinationsSearchField" value="{{ destinationInitialFilters.search|default('')|e('html_attr') }}">
                <div class="destinations-filters-head">
                    <h2 class="destinations-filters-title"><span>&#10024;</span> Trouvez votre voyage id&eacute;al</h2>
                    <p class="destinations-filters-copy">Personnalisez chaque d&eacute;tail de votre exp&eacute;rience</p>
                </div>

                <div class="destinations-filters-grid destinations-filters-grid-next">
                    <label class="destinations-filter-group destinations-filter-group-continent">
                        <span class="destinations-filter-label">&#127757; Destination</span>
                        <span class="destinations-filter-control">
                            <select id="destinationsContinentFilter" class="destinations-filter-input">
                                <option value="">&#127758; Tous les continents</option>
                            {% for continent in destinationFilterMeta.continents|default([]) %}
                                <option value="{{ continent }}">{{ continent }}</option>
                            {% endfor %}
                            </select>
                            <span class="destinations-select-chevron" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                        </span>
                    </label>

                    <div class="destinations-filter-group destinations-filter-group-budget">
                        <span class="destinations-filter-label">&#128142; Budget</span>
                        <div class="destinations-budget-row">
                            <label class="destinations-budget-field">
                                <span>&euro;</span>
                                <input type="number" id="destinationsBudgetMin" min="0" step="50" class="destinations-filter-input" placeholder="Min">
                            </label>
                            <label class="destinations-budget-field">
                                <span>&euro;</span>
                                <input type="number" id="destinationsBudgetMax" min="0" step="50" class="destinations-filter-input" placeholder="Max">
                            </label>
                        </div>
                    </div>

                    <label class="destinations-filter-group destinations-filter-group-date">
                        <span class="destinations-filter-label">&#128197; Depart</span>
                        <input type="date" id="destinationsDepartureFilter" class="destinations-filter-input">
                    </label>

                    <label class="destinations-filter-group destinations-filter-group-date">
                        <span class="destinations-filter-label">&#128197; Retour</span>
                        <input type="date" id="destinationsReturnFilter" class="destinations-filter-input">
                    </label>

                    <label class="destinations-filter-group destinations-filter-group-travel-type">
                        <span class="destinations-filter-label">&#129523; Type de voyage</span>
                        <span class="destinations-filter-control">
                            <select id="destinationsTravelTypeFilter" class="destinations-filter-input">
                                {% for travelType in destinationFilterMeta.travel_types|default(['Tous les profils', 'Famille', 'Couple', 'Solo', 'Business']) %}
                                    <option value="{{ travelType }}">
                                        {% if travelType == 'Tous les profils' %}
                                            &#128100; {{ travelType }}
                                        {% elseif travelType == 'Famille' %}
                                            &#128104;&#8205;&#128105;&#8205;&#128103;&#8205;&#128102; {{ travelType }}
                                        {% elseif travelType == 'Couple' %}
                                            &#128145; {{ travelType }}
                                        {% elseif travelType == 'Solo' %}
                                            &#129489; {{ travelType }}
                                        {% elseif travelType == 'Business' %}
                                            &#128188; {{ travelType }}
                                        {% else %}
                                            {{ travelType }}
                                        {% endif %}
                                    </option>
                                {% endfor %}
                            </select>
                            <span class="destinations-select-chevron" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                        </span>
                    </label>

                    <label class="destinations-filter-group destinations-filter-group-travelers">
                        <span class="destinations-filter-label">&#128101; Adultes</span>
                        <span class="destinations-filter-control">
                            <select id="destinationsAdultsFilter" class="destinations-filter-input">
                                {% for number in 1..6 %}
                                    <option value="{{ number }}">{{ number }} {{ number == 1 ? 'adulte' : 'adultes' }}</option>
                                {% endfor %}
                            </select>
                            <span class="destinations-select-chevron" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                        </span>
                    </label>

                    <label class="destinations-filter-group destinations-filter-group-travelers">
                        <span class="destinations-filter-label">&#128118; Enfants</span>
                        <span class="destinations-filter-control">
                            <select id="destinationsChildrenFilter" class="destinations-filter-input">
                                {% for number in 0..8 %}
                                    <option value="{{ number }}">{{ number }} {{ number <= 1 ? 'enfant' : 'enfants' }}</option>
                                {% endfor %}
                            </select>
                            <span class="destinations-select-chevron" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none"><path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                        </span>
                    </label>
                </div>

                <div class="destinations-interests-panel">
                    <div class="destinations-filter-label-row">
                        <span class="destinations-filter-label">&#10024; Vos envies de voyage</span>
                    </div>
                    <div class="destinations-interest-chips">
                        {% for interest in interestOptions %}
                            <button type="button" class="destinations-interest-chip" data-interest="{{ interest.name }}">
                                <span class="destinations-interest-icon">{{ interest.icon|raw }}</span>
                                <span class="destinations-interest-text">{{ interest.name }}</span>
                                <span class="destinations-interest-check" aria-hidden="true">&#10003;</span>
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <p class="destinations-filter-feedback" id="destinationsFilterFeedback" aria-live="polite"></p>
                <div class="destinations-agent-handoff" id="destinationsAgentHandoff">
                    <div>
                        <strong>Besoin d affiner ce voyage ?</strong>
                        <span>Votre profil est pret pour Travel-AI, meme si les recommandations automatiques ne repondent pas.</span>
                    </div>
                    <a href="/chat" class="destinations-agent-button" id="destinationsAgentButton">Passer a notre agent intelligent</a>
                </div>
            </div>
        </div>

        <section class="destinations-showcase about-scroll-reveal about-scroll-reveal-right" data-scroll-reveal>
            <div class="destinations-architecture-strip">
                <article class="destinations-architecture-card">
                    <span class="destinations-architecture-kicker">Bundle</span>
                    <strong>Workflow Symfony</strong>
                    <p>Le catalogue client n'affiche que les destinations publiees via le workflow.</p>
                </article>
                <article class="destinations-architecture-card">
                    <span class="destinations-architecture-kicker">Metier</span>
                    <strong>Score qualite {{ topQualityScore }}/100</strong>
                    <p>Les cartes sont triees par priorite catalogue puis par qualite metier.</p>
                </article>
                <article class="destinations-architecture-card">
                    <span class="destinations-architecture-kicker">Profils</span>
                    <strong>{{ destinationFilterMeta.travel_types|default([])|length - 1 }} types de voyage</strong>
                    <p>Famille, Couple, Solo et Business pilotent les voyageurs et la selection.</p>
                </article>
                <article class="destinations-architecture-card">
                    <span class="destinations-architecture-kicker">Bundle</span>
                    <strong>KNP Paginator</strong>
                    <p>Visible dans l'ecran de gestion des destinations pour paginer le catalogue.</p>
                </article>
            </div>

            <div class="destinations-showcase-header">
                <div class="destinations-showcase-copy-wrap">
                    <p class="destinations-showcase-kicker">Collections Signature</p>
                    <h2 class="destinations-showcase-title">Tous vos packs visibles d'un seul regard</h2>
                    <p class="destinations-showcase-copy" id="destinationsSummaryCopy">Explorez l'ensemble des offres premium sans carousel ni bloc cache, avec workflow de publication, score qualite et profils voyageurs visibles comme preuves du metier avance.</p>
                    <div class="destinations-showcase-pills">
                        <span class="destinations-showcase-pill">Workflow publie</span>
                        <span class="destinations-showcase-pill">Score qualite</span>
                        <span class="destinations-showcase-pill">Profils voyageurs</span>
                        <span class="destinations-showcase-pill">IA Flask</span>
                    </div>
                </div>
                <div class="destinations-showcase-badge">
                    <span class="destinations-count-kicker">PACKS</span>
                    <strong class="destinations-count-value" id="destinationsVisibleCount">{{ visibleCount }}</strong>
                </div>
            </div>

            <div class="destinations-grid" id="destinationsGrid">
                {% for destination in destinations %}
                    <article
                        class="destinations-card"
                        data-destination-card
                        data-search="{{ destination.search_blob|e('html_attr') }}"
                        data-name="{{ destination.destination_name|e('html_attr') }}"
                        data-country="{{ destination.country|e('html_attr') }}"
                        data-continent="{{ destination.continent|e('html_attr') }}"
                        data-price="{{ destination.price_amount }}"
                        data-travel-mood="{{ destination.travel_mood|e('html_attr') }}"
                        data-audiences="{{ destination.audiences|join('|')|e('html_attr') }}"
                        data-interests="{{ destination.interests|join('|')|e('html_attr') }}"
                        data-max-travelers="{{ destination.max_travelers }}"
                        data-image="{{ destination.image_path|e('html_attr') }}"
                        data-description="{{ destination.description|e('html_attr') }}"
                        data-duration="{{ destination.duration_label|e('html_attr') }}"
                        data-best-period="{{ destination.best_period|e('html_attr') }}"
                        data-price-label="{{ destination.price_label|e('html_attr') }}"
                        data-original-price-label="{{ destination.original_price_label|e('html_attr') }}"
                        data-original-price="{{ destination.original_price_amount|default(0) }}"
                        data-highlights="{{ destination.highlights|join('|')|e('html_attr') }}"
                        data-payment-path="{{ destination.payment_path|e('html_attr') }}"
                        data-contact-path="{{ destination.contact_path|e('html_attr') }}"
                        data-package-id="{{ destination.id|default(0) }}"
                        data-source="{{ destination.source|default('database')|e('html_attr') }}"
                        data-favorite-key="{{ destination.favorite_key|default('')|e('html_attr') }}"
                        data-is-favorite="{{ destination.is_favorite|default(false) ? '1' : '0' }}"
                    >
                        <div class="destinations-card-visual">
                            <img src="{{ destination.image_path }}" alt="{{ destination.destination_name }}" class="destinations-card-image">
                            <div class="destinations-card-overlay"></div>
                            <button
                                type="button"
                                class="destinations-favorite-button {{ destination.is_favorite|default(false) ? 'is-active' : '' }}"
                                data-favorite-toggle
                                aria-label="{{ destination.is_favorite|default(false) ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                                aria-pressed="{{ destination.is_favorite|default(false) ? 'true' : 'false' }}"
                            >
                                <span aria-hidden="true">&#9829;</span>
                            </button>
                            <div class="destinations-card-headline">
                                <div class="destinations-card-badge-row">
                                    <span class="destinations-card-badge">{{ destination.travel_mood }}</span>
                                    <span class="destinations-card-badge destinations-card-badge-alt">Publiee</span>
                                    <span class="destinations-card-badge destinations-card-badge-score">Score {{ destination.quality_score|default(0) }}/100</span>
                                </div>
                                <h3 class="destinations-card-title">{{ destination.destination_name }}</h3>
                                <p class="destinations-card-subtitle">{{ destination.subtitle }}</p>
                            </div>
                        </div>

                        <div class="destinations-card-body">
                            <p class="destinations-card-description">{{ destination.description }}</p>
                            <div class="destinations-card-meta">
                                <div>
                                    <span class="destinations-card-label">A partir de</span>
                                    <strong class="destinations-card-price" data-money data-money-base="TND" data-money-amount="{{ destination.price_amount }}">{{ destination.price_label }}</strong>
                                </div>
                                <div class="destinations-card-meta-right">
                                    <span class="destinations-card-label">Duree</span>
                                    <strong class="destinations-card-duration">{{ destination.duration_label }}</strong>
                                </div>
                            </div>
                            <div class="destinations-card-audience">
                                <span class="destinations-card-label">Profils</span>
                                <div class="destinations-card-tags destinations-card-tags-audience">
                                    {% for audience in destination.audiences|default([])|slice(0, 3) %}
                                        <span class="destinations-card-tag destinations-card-tag-audience">{{ audience }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                            <div class="destinations-card-tags">
                                {% for interest in destination.interests|slice(0, 3) %}
                                    <span class="destinations-card-tag">{{ interest }}</span>
                                {% endfor %}
                            </div>
                            <button type="button" class="destinations-card-action" data-open-destination-details>Voir details</button>
                        </div>
                    </article>
                {% endfor %}
            </div>

            <article class="destinations-empty-state" id="destinationsEmptyState" hidden>
                <h3 class="destinations-empty-title">Aucune destination ne correspond a vos filtres</h3>
                <p class="destinations-empty-copy">Ajustez le budget, le profil ou les envies pour relancer une nouvelle selection premium.</p>
            </article>
        </section>
    </section>

    <div class="destinations-details-overlay" id="destinationDetailsOverlay" hidden>
        <div class="destinations-details-backdrop" data-close-destination-details></div>
        <div class="destinations-details-modal" role="dialog" aria-modal="true" aria-labelledby="destinationDetailsTitle">
            <button type="button" class="destinations-details-close" data-close-destination-details aria-label="Fermer les details">&times;</button>
            <div class="destinations-details-hero">
                <img src="" alt="" class="destinations-details-image" id="destinationDetailsImage">
                <div class="destinations-details-hero-overlay"></div>
                <div class="destinations-details-hero-copy">
                    <span class="destinations-details-pill" id="destinationDetailsMood">Pack</span>
                    <h2 class="destinations-details-title" id="destinationDetailsTitle">Destination</h2>
                    <p class="destinations-details-subtitle" id="destinationDetailsSubtitle">Pays - Continent</p>
                </div>
            </div>

            <div class="destinations-details-body">
                <div class="destinations-details-topline">
                    <div class="destinations-details-price-block">
                        <span class="destinations-details-label">Budget indicatif</span>
                        <strong id="destinationDetailsPrice" data-money data-money-base="TND" data-money-amount="0">0 TND</strong>
                        <small id="destinationDetailsOriginalPrice" data-money data-money-base="TND" data-money-amount="0">0 TND</small>
                    </div>
                    <div class="destinations-details-inline-grid">
                        <div class="destinations-details-mini-card">
                            <span>Duree</span>
                            <strong id="destinationDetailsDuration">0 jours</strong>
                        </div>
                        <div class="destinations-details-mini-card">
                            <span>Voyageurs conseilles</span>
                            <strong id="destinationDetailsTravelers">0</strong>
                        </div>
                        <div class="destinations-details-mini-card">
                            <span>Meilleure periode</span>
                            <strong id="destinationDetailsBestPeriod">Toute l annee</strong>
                        </div>
                    </div>
                </div>

                <div class="destinations-details-content-grid">
                    <div class="destinations-details-copy">
                        <h3>Description</h3>
                        <p id="destinationDetailsDescription">Description de la destination.</p>
                    </div>
                    <div class="destinations-details-highlights">
                        <h3>Points forts</h3>
                        <ul id="destinationDetailsHighlights"></ul>
                    </div>
                </div>

                <div class="destinations-package-details">
                    <div class="destinations-package-head">
                        <div>
                            <span class="destinations-details-label">Pack IA Flask</span>
                            <h3>Details comme la version Java</h3>
                        </div>
                        <span class="destinations-package-status" id="destinationPackageStatus">En attente de selection</span>
                    </div>
                    <div class="destinations-package-grid" id="destinationPackageContent"></div>
                </div>

                <div class="destinations-details-actions">
                    <a href="/paiement" class="destinations-details-button" id="destinationDetailsReserve">Reserver maintenant</a>
                    <a href="/contact" class="destinations-details-button destinations-details-button-secondary" id="destinationDetailsPersonalize">Personnaliser ce voyage</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block extra_scripts %}
    <script src="/destinations.js"></script>
{% endblock %}
