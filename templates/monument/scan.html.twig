{% extends 'layout.html.twig' %}

{% block title %}Monument Recognition - EasyTravel{% endblock %}

    {% block stylesheets %}
        {{ parent() }}
        <link rel="stylesheet" href="/monument-scan.css">
    {% endblock %}

    {% block content %}
    <div class="monument-scan-container">
        <div class="scan-header">
            <h1>🏛️ Monument Recognition</h1>
            <p>Upload a photo of a monument, landmark, or historical building and let AI identify it for you!</p>
        </div>

        <form method="post" enctype="multipart/form-data" id="monument-upload-form">
            <div class="upload-area" id="upload-area">
                <div class="loading-overlay" id="loading-overlay">
                    <div class="spinner-large"></div>
                    <p>Analyzing your image...</p>
                </div>
                
                <span class="upload-icon">📷</span>
                <div class="upload-title">Drop your photo here</div>
                <p class="upload-subtitle">or click the button below to browse</p>
                
                <input type="file" id="monument_image" name="monument_image" accept="image/jpeg,image/png,image/webp" required>
                
                <label for="monument_image" class="upload-button" id="browse-btn">
                    📁 Choose Photo
                </label>

                <div class="or-divider">
                    <span>or drag and drop</span>
                </div>

                <div class="selected-file-name" id="selected-file-name"></div>

                <div class="file-preview" id="file-preview">
                    <img id="preview-img" src="" alt="Preview">
                    <p id="preview-filename"></p>
                </div>
            </div>

            <div class="error-box" id="error-box">
                <h3>❌ Upload Failed</h3>
                <p id="error-message"></p>
            </div>

            <div style="text-align: center; margin-top: 1.5rem;">
                <button type="submit" class="upload-button" id="submit-btn" disabled>
                    🔍 Recognize Monument
                </button>
            </div>
        </form>

        {% if error %}
        <div class="error-box active">
            <h3>❌ Recognition Failed</h3>
            <p>{{ error }}</p>
        </div>
        {% endif %}

        <!-- Result section (populated by JavaScript on successful upload) -->
        <div class="result-section" id="result-section" style="display: none;">
            <div class="result-card">
                <div class="result-header">
                    <div class="result-title" id="result-title"></div>
                    <div class="result-confidence" id="result-confidence"></div>
                </div>
                <div class="result-body">
                    <div class="result-image">
                        <img id="result-image" src="" alt="Monument">
                    </div>
                    <div class="result-info">
                        <h3 id="result-name"></h3>
                        <p class="result-location" id="result-location"></p>
                        <p class="result-description" id="result-description"></p>
                        <div class="result-actions">
                            <button type="button" class="btn btn-primary" id="add-to-request-btn">
                                ✈️ Add to Travel Request
                            </button>
                            <button type="button" class="btn btn-secondary" id="scan-another-btn">
                                📷 Scan Another
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if recentScans is defined and recentScans|length > 0 %}
            <div class="recent-scans" style="margin-top: 3rem;">
                <h2 style="color: #0b4a6e; margin-bottom: 1.5rem;">📸 Your Recent Scans</h2>
                <div class="scans-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem;">
                    {% for scan in recentScans %}
                        {% if scan.isSuccessful() %}
                            <div class="scan-card" style="background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);">
                                <img src="{{ scan.getImagePath() }}" alt="{{ scan.getMonumentName() }}" style="width: 100%; height: 150px; object-fit: cover;">
                                <div class="scan-card-content" style="padding: 1rem;">
                                    <div class="scan-card-title" style="font-weight: 600; color: #0b4a6e; margin-bottom: 0.25rem;">{{ scan.getMonumentName() }}</div>
                                    <div class="scan-card-location" style="color: #666; font-size: 0.9rem; margin-bottom: 0.5rem;">{{ scan.getFormattedLocation() }}</div>
                                    <div class="scan-card-date" style="color: #999; font-size: 0.8rem;">{{ scan.getCreatedAt().format('M d, Y') }}</div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}

    {% block javascripts %}
        {{ parent() }}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                console.log('Monument scan page loaded');
                
                const form = document.getElementById('monument-upload-form');
                const fileInput = document.getElementById('monument_image');
                const uploadArea = document.getElementById('upload-area');
                const browseBtn = document.getElementById('browse-btn');
                const submitBtn = document.getElementById('submit-btn');
                const selectedFileName = document.getElementById('selected-file-name');
                const filePreview = document.getElementById('file-preview');
                const previewImg = document.getElementById('preview-img');
                const previewFilename = document.getElementById('preview-filename');
                const loadingOverlay = document.getElementById('loading-overlay');
                const errorBox = document.getElementById('error-box');
                const errorMessage = document.getElementById('error-message');

                if (!fileInput) {
                    console.error('ERROR: File input element #monument_image not found!');
                    showError('Internal error: file input not found');
                    return;
                }

                console.log('File input element found:', fileInput);
                console.log('File input type:', fileInput.type);

                // File selection - CRITICAL
                fileInput.addEventListener('change', function(event) {
                    console.log('=== FILE INPUT CHANGE EVENT ===');
                    console.log('Event target:', event.target);
                    console.log('Files array length:', event.target.files.length);
                    
                    const file = event.target.files[0];
                    console.log('File object:', file);
                    
                    if (file) {
                        console.log('Processing file:', file.name, 'Size:', file.size, 'Type:', file.type);
                        handleFileSelect(file);
                    } else {
                        console.log('No file selected (event.target.files is empty)');
                    }
                });

                function handleFileSelect(file) {
                    console.log('handleFileSelect called with:', file.name, 'type:', file.type, 'size:', file.size);
                    
                    const validTypes = ['image/jpeg', 'image/png', 'image/webp'];
                    if (!validTypes.includes(file.type)) {
                        showError('Please upload a valid image file (JPEG, PNG, or WebP)');
                        return;
                    }

                    if (file.size > 10 * 1024 * 1024) {
                        showError('File size must be less than 10MB');
                        return;
                    }

                    selectedFileName.textContent = 'Selected: ' + file.name;
                    selectedFileName.style.display = 'block';
                    submitBtn.disabled = false;

                    const reader = new FileReader();
                    reader.onload = function(e) {
                        console.log('FileReader loaded, showing preview');
                        previewImg.src = e.target.result;
                        previewFilename.textContent = file.name;
                        filePreview.style.display = 'block';
                    };
                    reader.onerror = function() {
                        showError('Error reading file');
                    };
                    reader.readAsDataURL(file);

                    hideError();
                }

                // Form submission
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();

                    if (!fileInput.files.length) {
                        showError('Please select a file to upload');
                        return;
                    }

                    showLoading();

                    const formData = new FormData();
                    formData.append('monument_image', fileInput.files[0]);

                    try {
                        const response = await fetch('{{ path('app_monument_scan_process') }}', {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        console.log('Response status:', response.status);

                        const contentType = response.headers.get('content-type');
                        let data;

                        if (contentType && contentType.includes('application/json')) {
                            data = await response.json();
                            console.log('JSON data:', data);
                        } else {
                            const text = await response.text();
                            console.log('Non-JSON response:', text.substring(0, 200));
                            throw new Error('Server returned ' + response.status);
                        }

                        if (data.success) {
                            showResult(data.monumentScan);
                        } else {
                            showError(data.error || 'Failed to recognize monument.');
                            hideLoading();
                        }
                    } catch (error) {
                        console.error('Upload error:', error);
                        showError('Upload failed: ' + error.message);
                        hideLoading();
                    }
                });

                function showLoading() {
                    loadingOverlay.classList.add('active');
                    submitBtn.disabled = true;
                }

                function hideLoading() {
                    loadingOverlay.classList.remove('active');
                    submitBtn.disabled = false;
                }

                function showError(message) {
                    console.error('Error:', message);
                    errorMessage.textContent = message;
                    errorBox.classList.add('active');
                    errorBox.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }

                function hideError() {
                    errorBox.classList.remove('active');
                }

                function showResult(monumentScan) {
                    console.log('Showing result:', monumentScan);
                    
                    // Populate result fields
                    document.getElementById('result-title').textContent = monumentScan.monumentName;
                    document.getElementById('result-confidence').textContent = 'Confidence: ' + Math.round(monumentScan.confidence * 100) + '%';
                    document.getElementById('result-image').src = monumentScan.imagePath;
                    document.getElementById('result-name').textContent = monumentScan.monumentName;
                    document.getElementById('result-location').innerHTML = '📍 ' + monumentScan.city + ', ' + monumentScan.country;
                    document.getElementById('result-description').textContent = monumentScan.description;

                    // Set up "Add to Travel Request" button
                    const addBtn = document.getElementById('add-to-request-btn');
                    addBtn.onclick = async function() {
                        addBtn.disabled = true;
                        addBtn.textContent = 'Adding...';
                        
                        try {
                            const response = await fetch('{{ path('app_monument_add_to_request', {'id': 'SCAN_ID_PLACEHOLDER'}) }}'.replace('SCAN_ID_PLACEHOLDER', monumentScan.id), {
                                method: 'POST',
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            });
                            
                            const data = await response.json();
                            
                            if (data.success) {
                                addBtn.textContent = '✓ Added to Travel Request';
                                addBtn.style.background = 'linear-gradient(135deg, #28a745, #20c997)';
                                addBtn.disabled = true;
                                alert('Monument added to your travel request!');
                            } else {
                                alert('Error: ' + (data.error || 'Failed to add'));
                                addBtn.disabled = false;
                                addBtn.textContent = '✈️ Add to Travel Request';
                            }
                        } catch (error) {
                            console.error('Add to request error:', error);
                            alert('Network error. Please try again.');
                            addBtn.disabled = false;
                            addBtn.textContent = '✈️ Add to Travel Request';
                        }
                    };

                    // Show result section
                    const resultSection = document.getElementById('result-section');
                    resultSection.style.display = 'block';
                    resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

                    hideLoading();
                }

                // Scan Another button
                document.getElementById('scan-another-btn').addEventListener('click', function() {
                    form.reset();
                    selectedFileName.style.display = 'none';
                    selectedFileName.textContent = '';
                    filePreview.style.display = 'none';
                    previewImg.src = '';
                    previewFilename.textContent = '';
                    submitBtn.disabled = true;
                    document.getElementById('result-section').style.display = 'none';
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });

                console.log('Monument scan JavaScript initialized');
            });
        </script>
    {% endblock %}