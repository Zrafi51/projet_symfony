{% extends 'layout.html.twig' %}

{% block title %}{{ title|default(formTitle|default('Activite')) }}{% endblock %}

{% block content %}
    <section class="crud-hero crud-hero--editor">
        <div>
            <p class="hero-kicker">Edition</p>
            <h2>{{ formTitle|default('Activite') }}</h2>
            <p>Le select Destination relit la meme table que le projet Java, mais dans un template Symfony harmonise.</p>
        </div>
        <div class="crud-hero__aside">
            <a class="button button-outline-light" href="/activites">Retour a la liste</a>
        </div>
    </section>

    <section class="editor-panel">
        {% if errors|default([]) is not empty %}
            <div class="alert alert-error">
                {% for error in errors %}
                    <p>{{ error }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form class="stack" method="post" action="{{ action|default('') }}">
            <div class="form-grid">
                <label>
                    <span>Nom</span>
                    <input type="text" name="nom" value="{{ activite.nom|default('') }}" required>
                </label>

                <label>
                    <span>Destination</span>
                    <select name="destination_id" required>
                        <option value="">Choisir</option>
                        {% for destination in destinations|default([]) %}
                            <option value="{{ destination.id|default(0) }}" {{ (activite.destination_id|default('')) == (destination.id|default('')) ? 'selected' : '' }}>
                                {{ destination.nom|default('') }} - {{ destination.pays|default('') }}
                            </option>
                        {% endfor %}
                    </select>
                </label>
            </div>

            <div class="form-grid">
                <label>
                    <span>Categorie</span>
                    <input type="text" name="categorie" value="{{ activite.categorie|default('') }}" required>
                </label>

                <label>
                    <span>Prix</span>
                    <input type="number" step="0.01" min="0" name="prix" value="{{ activite.prix|default(0) }}" required>
                </label>
            </div>

            <label>
                <span>Duree (heures)</span>
                <input type="number" min="1" name="duree_heures" value="{{ activite.duree_heures|default(1) }}" required>
            </label>

            <label>
                <span>Description</span>
                <textarea name="description" rows="5">{{ activite.description|default('') }}</textarea>
            </label>

            <button class="button" type="submit">{{ submitLabel|default('Enregistrer') }}</button>
        </form>
    </section>
{% endblock %}
