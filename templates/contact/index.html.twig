{% extends 'about-layout.html.twig' %}

{% block extra_head %}
    <link rel="stylesheet" href="/contact.css">
{% endblock %}

{% block content %}
{% set isAuthenticated = currentUser and currentUser.email|default('') != '' %}
<section class="contact-page-section">
    <div class="contact-page-intro about-scroll-reveal about-scroll-reveal-hero" data-scroll-reveal>
        <p class="contact-page-kicker">CONTACT</p>
        <h1 class="contact-page-title">Parlons de votre voyage</h1>
        <p class="contact-page-subtitle">Notre equipe vous repond en moins de 24h</p>
    </div>

    <div class="contact-page-grid">
        <article class="contact-form-panel about-scroll-reveal about-scroll-reveal-left" data-scroll-reveal>
            <h2 class="contact-form-title">Envoyez un message</h2>

            <form method="post" action="/contact" class="contact-form-stack">
                <label class="contact-form-field">
                    <span>Nom complet</span>
                    <input
                        type="text"
                        name="name"
                        class="contact-form-input"
                        value="{{ formData.name|default('') }}"
                        placeholder="Votre nom complet"
                        {{ isAuthenticated ? 'readonly' : '' }}
                    >
                </label>

                <label class="contact-form-field">
                    <span>Email</span>
                    <input
                        type="email"
                        name="email"
                        class="contact-form-input"
                        value="{{ formData.email|default('') }}"
                        placeholder="Votre adresse email"
                        {{ isAuthenticated ? 'readonly' : '' }}
                    >
                </label>

                <label class="contact-form-field">
                    <span>Sujet</span>
                    <input
                        type="text"
                        name="subject"
                        class="contact-form-input"
                        value="{{ formData.subject|default('') }}"
                        placeholder="{{ isAuthenticated ? 'Sujet de votre reclamation' : 'Sujet de votre demande' }}"
                    >
                </label>

                <label class="contact-form-field">
                    <span>Telephone</span>
                    <input
                        type="text"
                        name="phone"
                        class="contact-form-input"
                        value="{{ formData.phone|default('') }}"
                        placeholder="Numero de telephone (optionnel)"
                    >
                </label>

                <label class="contact-form-field">
                    <span>Message</span>
                    <textarea
                        name="message"
                        rows="5"
                        class="contact-form-input contact-form-textarea"
                        placeholder="{{ isAuthenticated ? 'Expliquez clairement votre reclamation ou le probleme rencontre...' : 'Decrivez votre projet de voyage en detail...' }}"
                    >{{ formData.message|default('') }}</textarea>
                </label>

                <button type="submit" class="contact-submit-button">
                    {% if isAuthenticated %}
                        Envoyer la reclamation &#8594;
                    {% else %}
                        Envoyer le message &#8594;
                    {% endif %}
                </button>

                {% if statusMessage %}
                    <p class="contact-status-label contact-status-label-success">{{ statusMessage }}</p>
                {% endif %}
                {% if errorMessage %}
                    <p class="contact-status-label contact-status-label-error">{{ errorMessage }}</p>
                {% endif %}
            </form>
        </article>

        <aside class="contact-info-stack about-scroll-reveal about-scroll-reveal-right" data-scroll-reveal>
            <article class="contact-info-card contact-info-card-highlight">
                <div class="contact-info-icon-shell">
                    <span class="contact-info-icon">&#9742;</span>
                </div>
                <div class="contact-info-copy">
                    <h3>Appelez-nous</h3>
                    <p class="contact-info-main">+216 71 123 456</p>
                    <p class="contact-info-meta">Lun-Ven: 9h-18h</p>
                </div>
            </article>

            <article class="contact-info-card">
                <div class="contact-info-icon-shell contact-info-icon-shell-dark">
                    <span class="contact-info-icon">&#9993;</span>
                </div>
                <div class="contact-info-copy">
                    <h3>Email</h3>
                    <p class="contact-info-main contact-info-main-dark">contact@easytravel.tn</p>
                    <p class="contact-info-meta contact-info-meta-dark">Reponse sous 24h</p>
                </div>
            </article>

            <article class="contact-info-card">
                <div class="contact-info-icon-shell contact-info-icon-shell-dark">
                    <span class="contact-info-icon">&#128205;</span>
                </div>
                <div class="contact-info-copy">
                    <h3>Adresse</h3>
                    <p class="contact-info-main contact-info-main-dark">123 Avenue Habib Bourguiba</p>
                    <p class="contact-info-meta contact-info-meta-dark">Tunis 1000, Monastir</p>
                </div>
            </article>
        </aside>
    </div>
</section>
{% endblock %}
