{% set travelTypeOptions = {
    'couple': 'couple',
    'famille': 'famille',
    'aventure': 'aventure',
    'business': 'business'
} %}
{% set badgeOptions = ['Populaire', 'Nouveau', 'Exclusif'] %}
{% set continentOptions = ['Tous', 'Europe', 'Asie', 'Amerique', 'Afrique', 'Oceanie'] %}

<section class="admin-packages-shell">
    <div class="admin-packages-hero-grid">
        <article class="admin-panel-card admin-packages-hero-card">
            <div class="admin-packages-hero-head">
                <div class="admin-packages-hero-copy">
                    <h2>Packages / Offres</h2>
                    <p>Cette section alimente directement `OffersSection` sur la Home via la table `travel_packages`.</p>
                </div>
                <div class="admin-packages-hero-actions">
                    <button class="admin-primary-button" type="button" data-package-ai-open>Creer Package avec IA</button>
                    <a class="admin-card-action admin-card-action-blue" href="/">Voir la Home</a>
                </div>
            </div>

            <div class="admin-packages-pill-row">
                <span class="admin-range-pill admin-range-pill-active">Total {{ packageEntries|length }}</span>
                <span class="admin-range-pill">Actifs {{ travelPackageActiveCount }}</span>
                <span class="admin-range-pill">IA {{ travelPackageAiCount }}</span>
            </div>

            <div class="admin-packages-kpi-grid">
                <article class="admin-packages-mini-card">
                    <span>Packages</span>
                    <strong>{{ packageEntries|length }}</strong>
                </article>
                <article class="admin-packages-mini-card">
                    <span>Actifs</span>
                    <strong>{{ travelPackageActiveCount }}</strong>
                </article>
                <article class="admin-packages-mini-card">
                    <span>IA generes</span>
                    <strong>{{ travelPackageAiCount }}</strong>
                </article>
                <article class="admin-packages-mini-card">
                    <span>Score IA moyen</span>
                    <strong>{{ travelPackageAverageAiScore|default(0)|number_format(1, '.', '') }}</strong>
                </article>
            </div>
        </article>

        <aside class="admin-panel-card admin-packages-ranking-card">
            <h2>Packages les plus reserves</h2>
            <p>Classement calcule depuis les reservations reelles liees aux destinations.</p>

            {% if topReservedPackages is empty %}
                <p class="admin-empty-copy">Aucune reservation reliee pour le moment.</p>
            {% else %}
                <div class="admin-packages-ranking-list">
                    {% for stat in topReservedPackages %}
                        {% set rankingPackage = stat.travel_package|default({}) %}
                        {% set rankingToneClass = loop.index == 1 ? 'admin-packages-rank-gold' : (loop.index == 2 ? 'admin-packages-rank-silver' : 'admin-packages-rank-blue') %}
                        <article class="admin-packages-ranking-row">
                            <span class="admin-packages-rank-badge {{ rankingToneClass }}">#{{ loop.index }}</span>
                            <div class="admin-packages-ranking-copy">
                                <strong>{{ rankingPackage.package_name|default('Package') }}</strong>
                                <span>{{ rankingPackage.destinations|default('Destination') }} | {{ stat.reservation_count|default(0) }} reservations</span>
                            </div>
                            <div class="admin-packages-ranking-side">
                                {% set rankingRevenue = stat.revenue|default(0) %}
                                <strong>{{ rankingRevenue >= 1000000 ? 'EUR' ~ ((rankingRevenue / 1000000)|number_format(1, '.', ' ')) ~ 'M' : (rankingRevenue >= 1000 ? 'EUR' ~ ((rankingRevenue / 1000)|number_format(1, '.', ' ')) ~ 'K' : 'EUR' ~ (rankingRevenue|number_format(0, '.', ' '))) }}</strong>
                                <span>Score IA {{ rankingPackage.ai_score|default(0)|number_format(1, '.', '') }}</span>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </aside>
    </div>

    {% if packageEntries is empty %}
        <article class="admin-panel-card">
            <h2>Aucun package configure.</h2>
            <p>Utilisez le bouton IA pour creer les premiers packages ou remplissez la table `travel_packages`.</p>
        </article>
    {% else %}
        <section class="admin-packages-grid">
            {% for packageEntry in packageEntries %}
                {% set packageActive = packageEntry.is_active|default(false) %}
                {% set badgeTone = packageEntry.badge_tone|default('blue') %}
                {% set sourceTone = packageEntry.source_tone|default('blue') %}
                {% set reservationStats = packageEntry.reservation_stats|default({'reservation_count': 0, 'revenue': 0}) %}
                {% set priceFrom = packageEntry.price_from|default(0) %}
                {% set priceTo = packageEntry.price_to|default(0) %}
                <form class="admin-panel-card admin-packages-card" method="post" action="/admin/packages/{{ packageEntry.id|default(0) }}/save">
                    <input type="hidden" name="section" value="packages">

                    <div class="admin-packages-card-top">
                        <div class="admin-packages-chip-cluster">
                            <span class="admin-status-pill admin-status-pill-{{ sourceTone }}">{{ packageEntry.ai_generated|default(false) ? 'IA' : 'MANUAL' }}</span>
                            <span class="admin-status-pill admin-status-pill-{{ badgeTone }}">{{ packageEntry.badge|default('Nouveau') }}</span>
                            <span class="admin-status-pill {{ packageActive ? 'admin-status-pill-green' : 'admin-status-pill-red' }}">{{ packageActive ? 'ACTIF' : 'INACTIF' }}</span>
                        </div>
                        <span class="admin-packages-score-pill">Score IA {{ packageEntry.ai_score|default(0)|number_format(1, '.', '') }}</span>
                    </div>

                    <div class="admin-packages-field-grid admin-packages-field-grid-2">
                        <label>
                            <span>Titre</span>
                            <input class="admin-packages-input" type="text" name="package_name" value="{{ packageEntry.package_name|default('') }}">
                        </label>
                        <label>
                            <span>Destinations</span>
                            <input class="admin-packages-input" type="text" name="destinations" value="{{ packageEntry.destinations|default('') }}">
                        </label>
                    </div>

                    <div class="admin-packages-field-grid admin-packages-field-grid-3">
                        <label>
                            <span>Prix min</span>
                            <input class="admin-packages-input" type="text" name="price_from" value="{{ priceFrom|number_format(0, '.', '') }}">
                        </label>
                        <label>
                            <span>Prix max</span>
                            <input class="admin-packages-input" type="text" name="price_to" value="{{ priceTo|number_format(0, '.', '') }}">
                        </label>
                        <label>
                            <span>Duree</span>
                            <input class="admin-packages-input" type="text" name="duration_days" value="{{ packageEntry.duration_days|default(1) }}">
                        </label>
                    </div>

                    <div class="admin-packages-field-grid admin-packages-field-grid-3">
                        <label>
                            <span>Continent</span>
                            <input class="admin-packages-input" type="text" name="continent" value="{{ packageEntry.continent|default('') }}">
                        </label>
                        <label>
                            <span>Type voyage</span>
                            <select class="admin-packages-select" name="travel_type">
                                {% for travelTypeValue, travelTypeLabel in travelTypeOptions %}
                                    <option value="{{ travelTypeValue }}" {{ packageEntry.travel_type|default('')|lower == travelTypeValue ? 'selected' : '' }}>
                                        {{ travelTypeLabel }}
                                    </option>
                                {% endfor %}
                            </select>
                        </label>
                        <label>
                            <span>Badge</span>
                            <select class="admin-packages-select" name="badge">
                                {% for badgeOption in badgeOptions %}
                                    <option value="{{ badgeOption }}" {{ packageEntry.badge|default('')|lower == badgeOption|lower ? 'selected' : '' }}>
                                        {{ badgeOption }}
                                    </option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>

                    <label>
                        <span>Description</span>
                        <textarea class="admin-packages-textarea" name="description" rows="3">{{ packageEntry.description|default('') }}</textarea>
                    </label>

                    <div class="admin-packages-field-grid admin-packages-field-grid-2">
                        <label>
                            <span>Inclus</span>
                            <input class="admin-packages-input" type="text" name="includes" value="{{ packageEntry.includes|default('') }}">
                        </label>
                        <label>
                            <span>Meilleure periode</span>
                            <input class="admin-packages-input" type="text" name="best_period" value="{{ packageEntry.best_period|default('') }}">
                        </label>
                    </div>

                    <div class="admin-packages-state-row">
                        <label class="admin-packages-checkbox">
                            <input type="checkbox" name="is_active" value="1" {{ packageActive ? 'checked' : '' }}>
                            <span>Activer sur la Home</span>
                        </label>
                        <label class="admin-packages-flex-fill">
                            <span>Interets</span>
                            <input class="admin-packages-input" type="text" name="interests" value="{{ packageEntry.interests|default('') }}">
                        </label>
                    </div>

                    <div class="admin-packages-chip-row">
                        <article class="admin-packages-chip admin-packages-chip-orange">
                            <span>Prix</span>
                            <strong>{{ priceFrom >= 1000000 ? 'EUR' ~ ((priceFrom / 1000000)|number_format(1, '.', ' ')) ~ 'M' : (priceFrom >= 1000 ? 'EUR' ~ ((priceFrom / 1000)|number_format(1, '.', ' ')) ~ 'K' : 'EUR' ~ (priceFrom|number_format(0, '.', ' '))) }}</strong>
                        </article>
                        <article class="admin-packages-chip admin-packages-chip-blue">
                            <span>Duree</span>
                            <strong>{{ packageEntry.duration_days|default(1) }} j</strong>
                        </article>
                        <article class="admin-packages-chip admin-packages-chip-violet">
                            <span>Score IA</span>
                            <strong>{{ packageEntry.ai_score|default(0)|number_format(1, '.', '') }}</strong>
                        </article>
                    </div>

                    <div class="admin-packages-card-footer">
                        <div class="admin-packages-reservation-copy">
                            {% set reservationRevenue = reservationStats.revenue|default(0) %}
                            <strong>{{ reservationStats.reservation_count|default(0) }} reservation(s)</strong>
                            <span>{{ reservationRevenue >= 1000000 ? 'EUR' ~ ((reservationRevenue / 1000000)|number_format(1, '.', ' ')) ~ 'M' : (reservationRevenue >= 1000 ? 'EUR' ~ ((reservationRevenue / 1000)|number_format(1, '.', ' ')) ~ 'K' : 'EUR' ~ (reservationRevenue|number_format(0, '.', ' '))) }} cumules</span>
                        </div>
                        <button class="admin-card-action admin-card-action-green" type="submit">Sauvegarder</button>
                    </div>
                </form>
            {% endfor %}
        </section>
    {% endif %}

    <dialog class="admin-package-dialog" data-package-ai-dialog>
        <form class="admin-package-dialog-form" method="post" action="/admin/packages/generate-ai">
            <input type="hidden" name="section" value="packages">
            <div class="admin-package-dialog-head">
                <div>
                    <h2>Creer Package avec IA</h2>
                    <p>Le moteur local reprend l esprit du Java: top destinations compatibles, score IA puis synchronisation Home.</p>
                </div>
                <button class="admin-package-dialog-close" type="button" data-package-ai-close>X</button>
            </div>

            <div class="admin-packages-field-grid admin-packages-field-grid-2">
                <label>
                    <span>Type de voyage</span>
                    <select class="admin-packages-select" name="travel_type">
                        {% for travelTypeValue, travelTypeLabel in travelTypeOptions %}
                            <option value="{{ travelTypeValue }}">{{ travelTypeLabel|capitalize }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label>
                    <span>Continent</span>
                    <select class="admin-packages-select" name="continent">
                        {% for continentOption in continentOptions %}
                            <option value="{{ continentOption }}">{{ continentOption }}</option>
                        {% endfor %}
                    </select>
                </label>
            </div>

            <div class="admin-packages-field-grid admin-packages-field-grid-3">
                <label>
                    <span>Budget min</span>
                    <input class="admin-packages-input" type="text" name="budget_min" value="1200">
                </label>
                <label>
                    <span>Budget max</span>
                    <input class="admin-packages-input" type="text" name="budget_max" value="3200">
                </label>
                <label>
                    <span>Duree (jours)</span>
                    <input class="admin-packages-input" type="text" name="duration_days" value="7">
                </label>
            </div>

            <p class="admin-package-dialog-helper">Le moteur IA retourne jusqu a 3 packages bases sur les destinations et les reservations deja presentes en base.</p>

            <div class="admin-package-dialog-actions">
                <button class="admin-card-action admin-card-action-blue" type="button" data-package-ai-close>Annuler</button>
                <button class="admin-primary-button" type="submit">Generer avec IA</button>
            </div>
        </form>
    </dialog>
</section>
