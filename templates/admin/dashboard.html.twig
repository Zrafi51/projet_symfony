{% extends 'base.html.twig' %}

{% block title %}Administration - Forum Voyage{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-tachometer-alt me-2 text-primary"></i>Tableau de Bord</h2>
    <div class="btn-group">
        <a href="{{ path('app_admin_posts') }}" class="btn btn-outline-primary btn-sm"><i class="fas fa-newspaper me-1"></i>Posts</a>
        <a href="{{ path('app_admin_users') }}" class="btn btn-outline-primary btn-sm"><i class="fas fa-users me-1"></i>Utilisateurs</a>
        <a href="{{ path('app_admin_comments') }}" class="btn btn-outline-primary btn-sm"><i class="fas fa-comments me-1"></i>Commentaires</a>
        <a href="{{ path('app_admin_music') }}" class="btn btn-outline-primary btn-sm"><i class="fas fa-music me-1"></i>Playlist</a>
    </div>
</div>

{# Overview Stats #}
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                    <i class="fas fa-users fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">{{ totalUsers }}</h3>
                    <small>Utilisateurs</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-success text-white">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                    <i class="fas fa-newspaper fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">{{ totalPosts }}</h3>
                    <small>Publications</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-info text-white">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                    <i class="fas fa-comments fs-4"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-0">{{ totalComments }}</h3>
                    <small>Commentaires</small>
                </div>
            </div>
        </div>
    </div>
</div>

{# User Statistics Table #}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent">
        <h5 class="fw-bold mb-0"><i class="fas fa-chart-line me-2 text-primary"></i>Statistiques par Utilisateur</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Utilisateur</th>
                        <th class="text-center">Publications</th>
                        <th class="text-center">J'aime</th>
                        <th class="text-center">Réactions</th>
                        <th class="text-center">Commentaires</th>
                        <th class="text-center">Engagement</th>
                    </tr>
                </thead>
                <tbody>
                    {% for stat in userStats %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                {% if stat.user.profilePhotoPath %}
                                    <img src="{{ asset('uploads/profiles/' ~ stat.user.profilePhotoPath) }}"
                                         class="rounded-circle me-2" width="35" height="35" style="object-fit:cover" alt="">
                                {% else %}
                                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center me-2"
                                         style="width:35px;height:35px;">
                                        <span class="text-white small">{{ stat.user.username|first|upper }}</span>
                                    </div>
                                {% endif %}
                                <div>
                                    <strong>{{ stat.user.username }}</strong>
                                    {% if 'ROLE_ADMIN' in stat.user.roles %}
                                        <span class="badge bg-warning text-dark ms-1">Admin</span>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="text-center"><span class="badge bg-primary rounded-pill">{{ stat.postCount }}</span></td>
                        <td class="text-center"><span class="badge bg-danger rounded-pill">{{ stat.totalLikes }}</span></td>
                        <td class="text-center"><span class="badge bg-warning rounded-pill">{{ stat.totalReactions }}</span></td>
                        <td class="text-center"><span class="badge bg-info rounded-pill">{{ stat.totalComments }}</span></td>
                        <td class="text-center">
                            {% set engagement = stat.totalLikes + stat.totalReactions + stat.totalComments %}
                            <div class="progress" style="height: 8px; min-width: 80px;">
                                <div class="progress-bar bg-success" style="width: {{ engagement > 0 ? (engagement / (totalComments + 1) * 100)|round : 0 }}%"></div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# Admin Charts #}
<div class="row g-3 mt-3">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="fas fa-chart-pie me-2"></i>Répartition du contenu</h5>
                <canvas id="contentChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3"><i class="fas fa-chart-bar me-2"></i>Top Contributeurs</h5>
                <canvas id="contributorsChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Content distribution pie chart
    new Chart(document.getElementById('contentChart'), {
        type: 'doughnut',
        data: {
            labels: ['Publications', 'Commentaires', 'Utilisateurs'],
            datasets: [{
                data: [{{ totalPosts }}, {{ totalComments }}, {{ totalUsers }}],
                backgroundColor: ['#0d6efd', '#17a2b8', '#198754'],
                borderWidth: 2,
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });

    // Top contributors bar chart
    const stats = {{ userStats|json_encode|raw }};
    const names = stats.map(s => s.user.username);
    const posts = stats.map(s => s.postCount);

    new Chart(document.getElementById('contributorsChart'), {
        type: 'bar',
        data: {
            labels: names,
            datasets: [{
                label: 'Publications',
                data: posts,
                backgroundColor: 'rgba(13, 110, 253, 0.7)',
                borderRadius: 8,
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
    });
});
</script>
{% endblock %}
