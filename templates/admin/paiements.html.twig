{% extends 'admin-layout.html.twig' %}

{% block body %}
<main class="billing-admin-page">
    <section class="invoice-java-header">
        <div class="invoice-java-icon">PAY</div>
        <div>
            <h1>Gestion des Paiements</h1>
            <p>Creer, modifier et suivre les paiements avec le meme esprit que Java.</p>
        </div>
    </section>

    {% if statusMessage|default(null) %}
        <div class="billing-alert billing-alert-success">{{ statusMessage }}</div>
    {% endif %}
    {% if errorMessage|default(null) %}
        <div class="billing-alert billing-alert-error">{{ errorMessage }}</div>
    {% endif %}

    <section class="billing-stats-grid">
        <article class="billing-stat-card">
            <span>Total paiements</span>
            <strong>{{ stats.total|default(0) }}</strong>
        </article>
        <article class="billing-stat-card">
            <span>Payes</span>
            <strong>{{ stats.paid|default(0) }}</strong>
        </article>
        <article class="billing-stat-card">
            <span>Revenu paye</span>
            <strong>{{ stats.revenue|default(0)|number_format(2, '.', ' ') }} TND</strong>
        </article>
        <article class="billing-stat-card">
            <span>Dernier paiement</span>
            <strong>{{ stats.last_payment_at|default('') ?: 'Aucun' }}</strong>
        </article>
    </section>

    <section class="billing-admin-split">
        <form method="post" action="/admin/paiements/save" class="invoice-java-card">
            <input type="hidden" name="id" value="{{ formData.id|default(0) }}">

            <h2>{{ formData.id|default(0) > 0 ? 'Modifier le paiement' : 'Nouveau paiement' }}</h2>
            <label class="payment-field">
                <span>Nom du client</span>
                <input class="billing-input" name="client_nom" value="{{ formData.client_nom|default('') }}" placeholder="Ahmed Ben Ali" required>
            </label>
            <label class="payment-field">
                <span>Destination</span>
                <input class="billing-input" name="destination" value="{{ formData.destination|default('') }}" placeholder="Paris, France" required>
            </label>
            <div class="payment-field-grid">
                <label class="payment-field">
                    <span>Montant (TND)</span>
                    <input class="billing-input" type="number" step="0.01" min="0" name="montant" value="{{ formData.montant|default(0) }}" required>
                </label>
                <label class="payment-field">
                    <span>Date paiement</span>
                    <input class="billing-input" type="datetime-local" name="date_paiement" value="{{ formData.date_paiement|default('') }}" required>
                </label>
            </div>
            <div class="payment-field-grid">
                <label class="payment-field">
                    <span>Statut</span>
                    <select class="billing-input" name="statut">
                        {% for status in ['PAYE', 'EN_ATTENTE', 'REFUSE', 'REMBOURSE'] %}
                            <option value="{{ status }}" {{ formData.statut|default('PAYE') == status ? 'selected' : '' }}>{{ status }}</option>
                        {% endfor %}
                    </select>
                </label>
                <label class="payment-field">
                    <span>Type voyage</span>
                    <input class="billing-input" name="type_voyage" value="{{ formData.type_voyage|default('Aventure') }}" placeholder="Aventure">
                </label>
            </div>
            <div class="payment-field-grid">
                <label class="payment-field">
                    <span>ID package</span>
                    <input class="billing-input" type="number" min="0" name="package_id" value="{{ formData.package_id|default(0) }}">
                </label>
                <label class="payment-field">
                    <span>Carte masquee</span>
                    <input class="billing-input" name="numero_carte_masque" value="{{ formData.numero_carte_masque|default('') }}" placeholder="**** **** **** 1234">
                </label>
            </div>
            <label class="payment-field">
                <span>Reference transaction</span>
                <input class="billing-input" name="reference_transaction" value="{{ formData.reference_transaction|default('') }}" placeholder="Generee automatiquement si vide">
            </label>

            <div class="invoice-actions">
                <button type="submit" class="payment-button payment-button-primary">{{ formData.id|default(0) > 0 ? 'Mettre a jour' : 'Enregistrer' }}</button>
                <a href="/admin/paiements" class="payment-button payment-button-secondary">Nouveau formulaire</a>
                <a href="/admin/factures" class="payment-button payment-button-blue">Generer facture</a>
            </div>
        </form>

        <section class="invoice-java-card billing-list-card">
            <div class="billing-list-head">
                <div>
                    <h2>Historique des paiements</h2>
                    <p>{{ payments|default([])|length }} resultat(s)</p>
                </div>
                <form method="get" action="/admin/paiements" class="billing-search-form">
                    <input class="billing-input" name="q" value="{{ search|default('') }}" placeholder="Client, destination, reference...">
                    <button class="payment-button payment-button-secondary" type="submit">Rechercher</button>
                </form>
            </div>

            <div class="billing-payment-list">
                {% for payment in payments|default([]) %}
                    <article class="billing-payment-row">
                        <div>
                            <strong>{{ payment.client_nom }}</strong>
                            <span>{{ payment.destination }} | {{ payment.reference_transaction|default('Sans reference') }}</span>
                        </div>
                        <div class="billing-payment-meta">
                            <strong>{{ payment.montant|default(0)|number_format(2, '.', ' ') }} TND</strong>
                            <span class="billing-status-pill billing-status-{{ payment.statut|default('PAYE')|lower }}">{{ payment.statut|default('PAYE') }}</span>
                        </div>
                        <div class="billing-payment-actions">
                            <a href="/admin/paiements?edit={{ payment.id }}" class="payment-button payment-button-secondary">Modifier</a>
                            <a href="/admin/factures?payment_id={{ payment.id }}" class="payment-button payment-button-blue">Facture</a>
                            <form method="post" action="/admin/paiements/{{ payment.id }}/delete" onsubmit="return confirm('Supprimer ce paiement ?');">
                                <button type="submit" class="payment-button billing-danger-button">Supprimer</button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    <div class="billing-empty-state">
                        <strong>Aucun paiement trouve.</strong>
                        <span>Ajoutez un paiement ou lancez une recherche differente.</span>
                    </div>
                {% endfor %}
            </div>
        </section>
    </section>
</main>
{% endblock %}
