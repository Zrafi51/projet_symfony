{% extends 'base.html.twig' %}

{% block title %}Gestion des Commentaires - Admin{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="fas fa-comments me-2 text-primary"></i>Gestion des Commentaires</h2>
    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Retour
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Auteur</th>
                        <th>Commentaire</th>
                        <th>Publication</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for comment in comments %}
                    <tr>
                        <td>{{ comment.id }}</td>
                        <td><strong>{{ comment.auteur }}</strong></td>
                        <td>{{ comment.contenu|slice(0, 80) }}{% if comment.contenu|length > 80 %}...{% endif %}</td>
                        <td>
                            <a href="{{ path('app_post_show', {id: comment.post.id}) }}" class="text-decoration-none">
                                Post #{{ comment.post.id }}
                            </a>
                        </td>
                        <td><small>{{ comment.dateCommentaire|date('d/m/Y H:i') }}</small></td>
                        <td>
                            <form action="{{ path('app_admin_comment_delete', {id: comment.id}) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_comment' ~ comment.id) }}">
                                <button class="btn btn-outline-danger btn-sm" onclick="return confirm('Supprimer ce commentaire ?')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" class="text-center py-4 text-muted">Aucun commentaire</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
