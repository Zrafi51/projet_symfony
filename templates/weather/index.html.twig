{% extends 'weather-layout.html.twig' %}

{% set title = 'Meteo' %}
{% set path = '/weather' %}

{% block content %}
<div class="weather-page">
    <div class="weather-background"></div>
    <div class="container">
        <div class="weather-container">
            <div class="weather-header-card">
                <div class="weather-title-section">
                    <h1 class="weather-main-title">
                        <span class="weather-title-icon">🌤️</span>
                        Météo Mondiale
                    </h1>
                    <p class="weather-subtitle">Découvrez les conditions météo en temps réel</p>
                </div>
            </div>

            <div class="weather-search-card">
                {{ form_start(form, {'attr': {'class': 'weather-search-form', 'id': 'weatherForm'}}) }}
                <div class="search-input-group">
                    <div class="search-input-wrapper">
                        {{ form_widget(form.destination, {'attr': {'class': 'search-input', 'placeholder': '🔍 Rechercher une ville...', 'id': 'cityInput'}}) }}
                        <div class="search-icon">🔍</div>
                    </div>
                    {{ form_widget(form.search, {'attr': {'class': 'search-button', 'id': 'searchBtn'}}) }}
                </div>
                {{ form_end(form) }}

                {% if error %}
                    <div class="error-message">
                        <span class="error-icon">⚠️</span>
                        {{ error }}
                    </div>
                {% endif %}
            </div>

            {% if weatherData %}
                <div class="weather-result-card">
                    <div class="weather-result-header">
                        <div class="location-info">
                            <h2 class="city-name">{{ weatherData.city }}</h2>
                            <span class="country-name">{{ weatherData.country }}</span>
                        </div>
                        <div class="weather-time">
                            <span class="time-icon">🕐</span>
                            {{ "now"|date("H:i") }}
                        </div>
                    </div>

                    <div class="weather-main-display">
                        <div class="weather-visual">
                            <div class="weather-icon-wrapper">
                                <img src="https://openweathermap.org/img/wn/{{ weatherData.icon }}@4x.png" 
                                     alt="{{ weatherData.description }}" 
                                     class="weather-main-icon">
                                <div class="weather-icon-bg"></div>
                            </div>
                        </div>
                        
                        <div class="weather-info">
                            <div class="temperature-display">
                                <span class="temp-value">{{ weatherData.temperature|round }}</span>
                                <span class="temp-unit">°C</span>
                            </div>
                            <div class="weather-description">{{ weatherData.description|title }}</div>
                            <div class="feels-like">Ressenti {{ weatherData.feels_like|round }}°C</div>
                        </div>
                    </div>

                    <div class="weather-details">
                        <div class="detail-card">
                            <div class="detail-icon">💧</div>
                            <div class="detail-info">
                                <div class="detail-value">{{ weatherData.humidity }}%</div>
                                <div class="detail-label">Humidité</div>
                            </div>
                        </div>
                        
                        <div class="detail-card">
                            <div class="detail-icon">🌡️</div>
                            <div class="detail-info">
                                <div class="detail-value">{{ weatherData.pressure }}</div>
                                <div class="detail-label">Pression (hPa)</div>
                            </div>
                        </div>
                        
                        <div class="detail-card">
                            <div class="detail-icon">💨</div>
                            <div class="detail-info">
                                <div class="detail-value">{{ weatherData.wind_speed }}</div>
                                <div class="detail-label">Vent (m/s)</div>
                            </div>
                        </div>
                        
                        <div class="detail-card">
                            <div class="detail-icon">👁️</div>
                            <div class="detail-info">
                                <div class="detail-value">{{ weatherData.visibility / 1000 }}</div>
                                <div class="detail-label">Visibilité (km)</div>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
/* ===== BASE STYLES ===== */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    background: #0f0f23;
    color: #ffffff;
    line-height: 1.6;
}

/* ===== LAYOUT ===== */
.weather-page {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
}

.weather-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 20% 50%, #1e3c72 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, #2a5298 0%, transparent 50%),
        radial-gradient(circle at 40% 20%, #7e22ce 0%, transparent 50%),
        linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
    z-index: -2;
}

.weather-background::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
        radial-gradient(circle at 25% 25%, #ffffff08 2px, transparent 2px),
        radial-gradient(circle at 75% 75%, #ffffff08 1px, transparent 1px);
    background-size: 50px 50px, 30px 30px;
    animation: stars 120s linear infinite;
    z-index: -1;
}

@keyframes stars {
    0% { transform: translateY(0); }
    100% { transform: translateY(-100px); }
}

.weather-container {
    width: 100%;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

/* ===== HEADER ===== */
.weather-header-card {
    text-align: center;
    margin-bottom: 1rem;
}

.weather-main-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    background: linear-gradient(135deg, #60a5fa, #a78bfa, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    display: inline-flex;
    align-items: center;
    gap: 1rem;
}

.weather-title-icon {
    font-size: clamp(2rem, 4vw, 3rem);
    animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
}

.weather-subtitle {
    font-size: 1.1rem;
    color: #94a3b8;
    font-weight: 400;
}

/* ===== SEARCH CARD ===== */
.weather-search-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.8), rgba(51, 65, 85, 0.6));
    backdrop-filter: blur(20px);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 
        0 25px 50px -12px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.weather-search-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.search-input-group {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: stretch;
}

.search-input-wrapper {
    position: relative;
}

.search-input {
    width: 100%;
    padding: 1.25rem 3.5rem 1.25rem 1.5rem;
    background: rgba(15, 23, 42, 0.6);
    border: 2px solid rgba(148, 163, 184, 0.2);
    border-radius: 1rem;
    color: #ffffff;
    font-size: 1.1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    backdrop-filter: blur(10px);
}

.search-input::placeholder {
    color: #64748b;
}

.search-input:focus {
    outline: none;
    border-color: #60a5fa;
    background: rgba(15, 23, 42, 0.8);
    box-shadow: 
        0 0 0 4px rgba(96, 165, 250, 0.1),
        0 0 20px rgba(96, 165, 250, 0.2);
    transform: translateY(-2px);
}

.search-icon {
    position: absolute;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.3rem;
    color: #60a5fa;
    pointer-events: none;
}

.search-button {
    background: linear-gradient(135deg, #60a5fa, #3b82f6);
    border: none;
    border-radius: 1rem;
    padding: 1.25rem 2rem;
    font-size: 1.1rem;
    font-weight: 600;
    color: white;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
        0 4px 15px rgba(59, 130, 246, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    white-space: nowrap;
    position: relative;
    overflow: hidden;
}

.search-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: left 0.5s ease;
}

.search-button:hover::before {
    left: 100%;
}

.search-button:hover {
    transform: translateY(-2px);
    box-shadow: 
        0 8px 25px rgba(59, 130, 246, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.search-button:active {
    transform: translateY(0);
}

/* ===== ERROR MESSAGE ===== */
.error-message {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: slideIn 0.5s ease-out;
    box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3);
}

.error-icon {
    font-size: 1.3rem;
    animation: pulse 1s ease-in-out infinite;
}

@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateX(-20px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

/* ===== RESULT CARD ===== */
.weather-result-card {
    background: linear-gradient(135deg, rgba(30, 41, 59, 0.9), rgba(51, 65, 85, 0.7));
    backdrop-filter: blur(20px);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 2rem;
    padding: 2.5rem;
    box-shadow: 
        0 25px 50px -12px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    animation: slideUp 0.6s ease-out;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.weather-result-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
}

.location-info {
    text-align: left;
}

.city-name {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 0.25rem;
    letter-spacing: -0.02em;
}

.country-name {
    font-size: 1.1rem;
    color: #60a5fa;
    font-weight: 500;
}

.weather-time {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.9rem;
    font-weight: 500;
}

.time-icon {
    font-size: 1rem;
}

/* ===== MAIN DISPLAY ===== */
.weather-main-display {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
}

.weather-visual {
    position: relative;
}

.weather-icon-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.weather-main-icon {
    width: clamp(120px, 15vw, 180px);
    height: clamp(120px, 15vw, 180px);
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.4));
    animation: float 4s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
}

.weather-icon-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(150px, 20vw, 220px);
    height: clamp(150px, 20vw, 220px);
    background: radial-gradient(circle, rgba(96, 165, 250, 0.1) 0%, transparent 70%);
    border-radius: 50%;
    animation: rotate 30s linear infinite;
}

@keyframes rotate {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
}

.weather-info {
    text-align: left;
}

.temperature-display {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 1rem;
}

.temp-value {
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 900;
    background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    letter-spacing: -0.05em;
}

.temp-unit {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 600;
    color: #60a5fa;
    margin-top: 0.5rem;
}

.weather-description {
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    color: #e2e8f0;
    font-weight: 500;
    margin-bottom: 0.5rem;
    text-transform: capitalize;
    letter-spacing: 0.02em;
}

.feels-like {
    font-size: 1rem;
    color: #94a3b8;
    font-weight: 400;
}

/* ===== DETAILS GRID ===== */
.weather-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
}

.detail-card {
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.6), rgba(30, 41, 59, 0.4));
    border: 1px solid rgba(148, 163, 184, 0.1);
    border-radius: 1.2rem;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.detail-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(96, 165, 250, 0.1), transparent);
    transition: left 0.6s ease;
}

.detail-card:hover::before {
    left: 100%;
}

.detail-card:hover {
    transform: translateY(-4px);
    border-color: rgba(96, 165, 250, 0.3);
    box-shadow: 
        0 10px 25px rgba(0, 0, 0, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.detail-icon {
    font-size: 2rem;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.2), rgba(59, 130, 246, 0.1));
    border-radius: 1rem;
    border: 1px solid rgba(96, 165, 250, 0.2);
    flex-shrink: 0;
}

.detail-info {
    flex: 1;
    min-width: 0;
}

.detail-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 0.25rem;
    line-height: 1.2;
}

.detail-label {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ===== RESPONSIVE DESIGN ===== */
@media (max-width: 768px) {
    .weather-page {
        padding: 1rem;
    }
    
    .weather-search-card,
    .weather-result-card {
        padding: 1.5rem;
    }
    
    .search-input-group {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    
    .search-button {
        width: 100%;
    }
    
    .weather-result-header {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
    }
    
    .weather-main-display {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 2rem;
    }
    
    .weather-info {
        text-align: center;
    }
    
    .weather-details {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    
    .detail-card {
        padding: 1rem;
    }
    
    .detail-icon {
        width: 50px;
        height: 50px;
        font-size: 1.5rem;
    }
    
    .detail-value {
        font-size: 1.2rem;
    }
}

@media (max-width: 480px) {
    .weather-details {
        grid-template-columns: 1fr;
    }
    
    .detail-card {
        flex-direction: column;
        text-align: center;
        gap: 0.75rem;
    }
    
    .detail-icon {
        width: 60px;
        height: 60px;
        font-size: 2rem;
    }
}

/* ===== ACCESSIBILITY ===== */
@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}

/* ===== FOCUS STYLES ===== */
.search-button:focus,
.search-input:focus {
    outline: 2px solid #60a5fa;
    outline-offset: 2px;
}
</style>
{% endblock %}
