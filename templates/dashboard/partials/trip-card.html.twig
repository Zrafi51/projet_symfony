{% set tripDestination = trip.destination|default('Destination') %}
{% set tripType = trip.type_voyage|default(trip.travel_type|default('Voyage')) %}
{% set tripStart = trip.dateDepart|default(trip.date_depart|default(trip.date_paiement|default(''))) %}
{% set tripEnd = trip.dateRetour|default(trip.date_retour|default(trip.date_paiement|default(''))) %}
{% set tripTravelers = trip.nbPlaces|default(trip.nb_places|default(1)) %}
{% set tripAmount = trip.prix|default(trip.montant|default(0)) %}
{# Carte de voyage (a venir ou historique) #}
<div class="trip-card">
    <div class="trip-image-shell">
        <img src="/assets/java/bali-1-1679062958.profileImage.2x-1536x884.webp" alt="{{ tripDestination }}" class="trip-image">
        <div class="trip-image-shade"></div>
        <div class="trip-image-overlay">
            <span class="trip-image-eyebrow">{{ isHistory ? 'Souvenir client' : 'A venir' }}</span>
            <h3 class="trip-image-title">{{ tripDestination }}</h3>
            <p class="trip-image-subtitle">{{ tripType }} | {{ tripStart ? tripStart|date('d/m/Y') : 'Date a confirmer' }}</p>
        </div>
        <span class="status-badge status-{{ isHistory ? 'neutral' : 'success' }}">
            {{ isHistory ? 'TERMINE' : 'CONFIRME' }}
        </span>
        {% if not isHistory %}
            <span class="trip-countdown-badge">Bientot</span>
        {% endif %}
    </div>
    <div class="trip-card-body">
        <h3 class="section-card-title">{{ isHistory ? 'Carnet de voyage archive' : 'Votre prochaine escapade premium' }}</h3>
        <p class="trip-summary-text">
            {{ isHistory
                ? 'Retrouvez les details de ' ~ tripDestination ~ ' et partagez vos souvenirs sur le forum quand vous le souhaitez.'
                : 'Suivez votre prochain voyage avec une carte claire, imagee et facile a relire avant le depart.'
            }}
        </p>
        <div class="trip-pill-row">
            <span class="trip-info-pill trip-info-pill-accent">{{ tripStart ? tripStart|date('d/m/Y') : 'A confirmer' }}</span>
            <span class="trip-info-pill trip-info-pill-soft">{{ tripTravelers }} voyageur{{ tripTravelers > 1 ? 's' : '' }}</span>
        </div>
        <p class="section-card-text">
            {{ tripStart ? tripStart|date('d/m/Y') : 'A confirmer' }}
            {% if tripEnd %} - {{ tripEnd|date('d/m/Y') }}{% endif %}
            | {{ tripTravelers }} voyageur{{ tripTravelers > 1 ? 's' : '' }}
            | {{ tripAmount|number_format(0, '.', ' ') }} EUR
        </p>
        <div class="trip-actions">
            <a href="/destinations" class="card-button card-button-primary">{{ isHistory ? 'Voir destination' : 'Voir details' }}</a>
            <a href="{{ isHistory ? '/forum' : '/contact' }}" class="card-button card-button-outline">{{ isHistory ? 'Partager au forum' : 'Personnaliser' }}</a>
        </div>
    </div>
</div>
