{# Carte de reclamation avec reponses #}
<div class="reclamation-card">
    <div class="reclamation-header">
        <div class="reclamation-titles">
            <h3 class="reclamation-title">{{ reclamation.sujet|default('Reclamation #' ~ reclamation.id) }}</h3>
            <p class="reclamation-meta">
                {{ reclamation.created_at|date('d/m/Y H:i') }} | {{ responses|length }} reponse(s)
            </p>
        </div>
        <span class="reclamation-status status-badge status-{{ reclamation.statut == 'RESOLUE' ? 'success' : (reclamation.statut == 'REJETEE' ? 'danger' : (reclamation.statut == 'EN_COURS' ? 'info' : 'warning')) }}">
            {{ reclamation.statut|replace({'_': ' '}) }}
        </span>
    </div>

    <p class="reclamation-description">{{ reclamation.description|default('Aucune description fournie.') }}</p>

    {% if responses is not empty %}
        <div class="responses-thread">
            {% for response in responses %}
                <div class="response-bubble">
                    <div class="response-header">
                        <span class="response-author">{{ response.admin_name|default('Administration') }}</span>
                        <span class="response-time">{{ response.created_at|date('d/m/Y H:i') }}</span>
                    </div>
                    <p class="response-content">{{ response.contenu }}</p>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <div class="reclamation-actions">
        <a href="/contact" class="card-button card-button-outline">Nouvelle reclamation</a>
    </div>
</div>
