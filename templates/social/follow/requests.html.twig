{% extends 'social/base.html.twig' %}

{% block title %}Demandes d'abonnement - Forum Voyage{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold mb-0"><i class="fas fa-user-clock me-2 text-primary"></i>Demandes d'abonnement</h3>
            <a href="{{ path('forum_profile') }}" class="btn btn-link text-muted"><i class="fas fa-arrow-left me-1"></i>Retour</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                {% if pending is empty %}
                    <div class="text-center py-5">
                        <i class="fas fa-check-circle text-success fs-1"></i>
                        <p class="text-muted mt-3 mb-0">Aucune demande en attente.</p>
                    </div>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for req in pending %}
                            <div class="list-group-item d-flex align-items-center gap-3 py-3">
                                {% set photo = photoMap[req.followerUsername] ?? null %}
                                {% if photo %}
                                    <img src="{{ asset('uploads/profiles/' ~ photo) }}"
                                         class="rounded-circle" style="width:48px;height:48px;object-fit:cover;">
                                {% else %}
                                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center"
                                         style="width:48px;height:48px;">
                                        <span class="text-white fw-bold">{{ req.followerUsername|first|upper }}</span>
                                    </div>
                                {% endif %}
                                <div class="flex-grow-1">
                                    <a href="{{ path('forum_user_profile', {username: req.followerUsername}) }}"
                                       class="text-decoration-none text-dark"><strong>{{ req.followerUsername }}</strong></a>
                                    <br><small class="text-muted">veut s'abonner · {{ req.createdAt|date('d/m/Y H:i') }}</small>
                                </div>
                                <form method="post" action="{{ path('forum_follow_accept', {id: req.id}) }}" class="d-inline">
                                    <button class="btn btn-primary btn-sm" type="submit"><i class="fas fa-check me-1"></i>Accepter</button>
                                </form>
                                <form method="post" action="{{ path('forum_follow_reject', {id: req.id}) }}" class="d-inline">
                                    <button class="btn btn-outline-secondary btn-sm" type="submit"><i class="fas fa-times me-1"></i>Refuser</button>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
