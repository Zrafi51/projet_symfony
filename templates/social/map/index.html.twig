{% extends 'social/base.html.twig' %}

{% block title %}Carte - Forum Voyage{% endblock %}

{% block body %}
{# ─────────────────────────────────────────────────────────────────────────
   La carte est rendue par le BUNDLE OFFICIEL Symfony UX Map (Leaflet).
   {{ ux_map(map: map) }} est une fonction Twig fournie par le bundle.
   Elle génère le HTML + les data-attributes Stimulus qui déclenchent le
   chargement de Leaflet.js via importmap (pas de CDN, pas de script manuel).
   ───────────────────────────────────────────────────────────────────────── #}

<div class="map-wrapper">
    <div class="map-header d-flex align-items-center justify-content-between px-3 py-2 bg-white border-bottom">
        <a href="{{ path('forum_forum') }}" class="btn btn-link text-muted p-0">
            <i class="fas fa-arrow-left fs-5"></i>
        </a>
        <h5 class="m-0">
            <i class="fas fa-map-location-dot me-2 text-primary"></i>Carte des amis
            <small class="text-muted">(Symfony UX Map)</small>
        </h5>
        <span></span>
    </div>

    {# Banner — statut du pin #}
    <div id="mapStatusBanner" class="map-status px-3 py-2 small text-center">
        {% if mine %}
            <span class="text-success">
                <i class="fas fa-location-dot me-1"></i>
                Votre position est partagée jusqu'à
                <strong>{{ mine.expiresAt|date('H:i') }}</strong>
                ({{ mine.expiresAt|date('d/m/Y') }})
            </span>
            <button type="button" class="btn btn-sm btn-outline-danger ms-2" id="mapUnpinBtn">
                <i class="fas fa-xmark me-1"></i>Retirer
            </button>
        {% else %}
            <span class="text-muted">
                <i class="fas fa-circle-info me-1"></i>
                Localisation non partagée — appuyez sur « Partager ma position » pour apparaître sur la carte.
            </span>
        {% endif %}
    </div>

    {# ─── La carte rendue par le bundle UX Map ─── #}
    {{ ux_map(map: map, attributes: {
        style: 'width: 100%; height: 62vh; min-height: 420px;',
    }) }}

    {# Compose panel — bottom sheet. #}
    <div class="map-compose border-top bg-white p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Durée</label>
                <select class="form-select form-select-sm" id="mapTtl">
                    <option value="1">1 heure</option>
                    <option value="4" selected>4 heures</option>
                    <option value="8">8 heures</option>
                    <option value="24">24 heures</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Note (optionnel)</label>
                <input type="text" class="form-control form-control-sm" id="mapLabel"
                       maxlength="120" placeholder="Ex: Café du coin ☕">
            </div>
            <div class="col-md-3 d-grid gap-1">
                <label class="form-label small text-muted mb-1 d-none d-md-block">&nbsp;</label>
                <button type="button" class="btn btn-primary btn-sm" id="mapShareBtn">
                    <i class="fas fa-location-crosshairs me-1"></i>Partager ma position
                </button>
            </div>
        </div>
        <div class="small text-muted mt-2">
            <i class="fas fa-shield-halved me-1"></i>
            Seules les personnes que vous suivez peuvent voir votre pin.
            <br>
            <i class="fas fa-cube me-1"></i>
            Carte rendue par le bundle <strong>symfony/ux-leaflet-map</strong>.
        </div>
    </div>
</div>

<style>
.map-wrapper {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.08);
}
.map-status { background: #f8f9fa; }
</style>

<script>
(function () {
    var CSRF      = {{ csrf_token('map_pin')|json_encode|raw }};
    var PIN_URL   = {{ path('forum_map_pin')|json_encode|raw }};
    var UNPIN_URL = {{ path('forum_map_unpin')|json_encode|raw }};

    // ── Bouton "Partager ma position" : géolocalisation + AJAX vers /map/pin ──
    var shareBtn = document.getElementById('mapShareBtn');
    if (shareBtn) {
        shareBtn.addEventListener('click', function () {
            if (!navigator.geolocation) {
                alert('La géolocalisation n\'est pas disponible sur votre navigateur.');
                return;
            }
            shareBtn.disabled = true;
            shareBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Localisation...';
            navigator.geolocation.getCurrentPosition(function (pos) {
                var body = new URLSearchParams();
                body.append('_token', CSRF);
                body.append('lat', pos.coords.latitude);
                body.append('lng', pos.coords.longitude);
                body.append('ttlHours', document.getElementById('mapTtl').value);
                body.append('label', document.getElementById('mapLabel').value);
                fetch(PIN_URL, { method: 'POST', body: body, credentials: 'same-origin' })
                    .then(function (r) { return r.json(); })
                    .then(function (j) {
                        if (j.ok) { window.location.reload(); }
                        else {
                            alert('Erreur: ' + (j.error || 'inconnue'));
                            shareBtn.disabled = false;
                            shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position';
                        }
                    })
                    .catch(function () { shareBtn.disabled = false; });
            }, function (err) {
                alert('Impossible d\'obtenir votre position: ' + err.message);
                shareBtn.disabled = false;
                shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position';
            }, { enableHighAccuracy: true, timeout: 10000 });
        });
    }

    // ── Bouton "Retirer mon pin" ──
    var unpinBtn = document.getElementById('mapUnpinBtn');
    if (unpinBtn) {
        unpinBtn.addEventListener('click', function () {
            if (!confirm('Retirer votre position de la carte ?')) return;
            var body = new URLSearchParams();
            body.append('_token', CSRF);
            fetch(UNPIN_URL, { method: 'POST', body: body, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (j) { if (j.ok) window.location.reload(); });
        });
    }
})();
</script>
{% endblock %}
