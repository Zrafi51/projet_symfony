{% extends 'social/base.html.twig' %}

{% block title %}Carte - Forum Voyage{% endblock %}

{% block body %}
{# Leaflet.js — free OpenStreetMap tiles, no API key required. Loaded from
   CDN. The map renders pins of me + the people I follow whose pins haven't
   expired yet. A bottom panel lets me drop (or replace) my own pin with a
   TTL of 1/4/8/24 hours. #}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<div class="map-wrapper">
    <div class="map-header d-flex align-items-center justify-content-between px-3 py-2 bg-white border-bottom">
        <a href="{{ path('forum_forum') }}" class="btn btn-link text-muted p-0">
            <i class="fas fa-arrow-left fs-5"></i>
        </a>
        <h5 class="m-0"><i class="fas fa-map-location-dot me-2 text-primary"></i>Carte des amis</h5>
        <span></span>
    </div>

    {# Banner — shows current pin status + quick unpin button when I'm on the map. #}
    <div id="mapStatusBanner" class="map-status px-3 py-2 small text-center">
        {% if mine %}
            <span class="text-success">
                <i class="fas fa-location-dot me-1"></i>
                Votre position est partagée jusqu'à
                <strong>{{ mine.expiresAt|date('H:i') }}</strong>
                ({{ mine.expiresAt|date('d/m/Y') }})
            </span>
            <button type="button" class="btn btn-sm btn-outline-danger ms-2" id="mapUnpinBtn">
                <i class="fas fa-xmark me-1"></i>Retirer
            </button>
        {% else %}
            <span class="text-muted">
                <i class="fas fa-circle-info me-1"></i>
                Localisation non partagée — appuyez sur « Partager ma position » pour apparaître sur la carte.
            </span>
        {% endif %}
    </div>

    <div id="map"></div>

    {# Compose panel — bottom sheet. #}
    <div class="map-compose border-top bg-white p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Durée</label>
                <select class="form-select form-select-sm" id="mapTtl">
                    <option value="1">1 heure</option>
                    <option value="4" selected>4 heures</option>
                    <option value="8">8 heures</option>
                    <option value="24">24 heures</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Note (optionnel)</label>
                <input type="text" class="form-control form-control-sm" id="mapLabel"
                       maxlength="120" placeholder="Ex: Café du coin ☕">
            </div>
            <div class="col-md-3 d-grid gap-1">
                <label class="form-label small text-muted mb-1 d-none d-md-block">&nbsp;</label>
                <button type="button" class="btn btn-primary btn-sm" id="mapShareBtn">
                    <i class="fas fa-location-crosshairs me-1"></i>Partager ma position
                </button>
                <button type="button" class="btn btn-outline-primary btn-sm" id="mapManualBtn">
                    <i class="fas fa-hand-pointer me-1"></i>Épingler manuellement
                </button>
            </div>
        </div>
        {# Manual-pin instruction + confirm/cancel — only visible when the user
           has activated manual mode by clicking the button above. #}
        <div id="mapManualPanel" class="mt-2 d-none">
            <div class="alert alert-info py-2 mb-2 small d-flex align-items-center gap-2">
                <i class="fas fa-circle-info"></i>
                <span id="mapManualHint">Cliquez sur la carte pour placer votre épingle.</span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-success btn-sm" id="mapManualConfirm" disabled>
                    <i class="fas fa-check me-1"></i>Confirmer cette position
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="mapManualCancel">
                    <i class="fas fa-xmark me-1"></i>Annuler
                </button>
            </div>
        </div>
        <div class="small text-muted mt-2">
            <i class="fas fa-shield-halved me-1"></i>
            Seules les personnes que vous suivez peuvent voir votre pin.
        </div>
    </div>
</div>

<style>
.map-wrapper {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.08);
}
#map {
    width: 100%;
    height: 62vh;
    min-height: 420px;
}
.map-status { background: #f8f9fa; }
.map-avatar-marker {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 3px solid #1877f2;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0,0,0,.25);
}
.map-avatar-marker img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.map-avatar-marker.mine { border-color: #dc3545; }
.map-avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #6c757d;
    color: #fff;
    font-weight: bold;
    font-size: 1.1rem;
}
</style>

<script>
(function () {
    // Bootstrap data from the controller. Lists every ACTIVE pin the viewer is
    // allowed to see (me + people I follow), already filtered + sorted server
    // side.
    var MARKERS  = {{ markers|json_encode|raw }};
    var CSRF     = {{ csrf_token('map_pin')|json_encode|raw }};
    var PIN_URL  = {{ path('forum_map_pin')|json_encode|raw }};
    var UNPIN_URL= {{ path('forum_map_unpin')|json_encode|raw }};
    var PHOTO_BASE = {{ asset('uploads/profiles/')|json_encode|raw }};

    // Default view — roughly centred on Tunisia (same region shown in the
    // reference screenshots). Zoom 6 shows the whole country.
    var defaultCenter = [34.0, 9.5];
    var defaultZoom = 6;

    // If the current user already has a pin, centre on it.
    var mine = MARKERS.filter(function (m) { return m.isMine; })[0];
    if (mine) {
        defaultCenter = [mine.lat, mine.lng];
        defaultZoom = 10;
    }

    var map = L.map('map').setView(defaultCenter, defaultZoom);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors',
        maxZoom: 19
    }).addTo(map);

    function buildAvatarIcon(marker) {
        var inner = marker.photo
            ? '<img src="' + PHOTO_BASE + encodeURIComponent(marker.photo) + '" alt="">'
            : '<div class="map-avatar-fallback">' + (marker.username || '?').charAt(0).toUpperCase() + '</div>';
        var klass = 'map-avatar-marker' + (marker.isMine ? ' mine' : '');
        return L.divIcon({
            className: '',
            html: '<div class="' + klass + '">' + inner + '</div>',
            iconSize: [44, 44],
            iconAnchor: [22, 22],
            popupAnchor: [0, -20]
        });
    }

    MARKERS.forEach(function (m) {
        var exp = new Date(m.expiresAt);
        var hh = exp.getHours().toString().padStart(2, '0');
        var mm = exp.getMinutes().toString().padStart(2, '0');
        var popup = '<strong>' + m.username + '</strong>'
                  + (m.label ? '<div class="fst-italic text-muted">' + m.label + '</div>' : '')
                  + '<div class="small text-muted">Visible jusqu\'à ' + hh + ':' + mm + '</div>';
        L.marker([m.lat, m.lng], { icon: buildAvatarIcon(m) }).addTo(map).bindPopup(popup);
    });

    // — Share location —
    var shareBtn = document.getElementById('mapShareBtn');
    shareBtn.addEventListener('click', function () {
        if (!navigator.geolocation) {
            alert('La géolocalisation n\'est pas disponible sur votre navigateur.');
            return;
        }
        shareBtn.disabled = true;
        shareBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Localisation...';
        navigator.geolocation.getCurrentPosition(function (pos) {
            var lat = pos.coords.latitude;
            var lng = pos.coords.longitude;
            var ttl = document.getElementById('mapTtl').value;
            var label = document.getElementById('mapLabel').value;
            var body = new URLSearchParams();
            body.append('_token', CSRF);
            body.append('lat', lat);
            body.append('lng', lng);
            body.append('ttlHours', ttl);
            body.append('label', label);
            fetch(PIN_URL, { method: 'POST', body: body, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (j) {
                    if (j.ok) { window.location.reload(); }
                    else { alert('Erreur: ' + (j.error || 'inconnue')); shareBtn.disabled = false; shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position'; }
                })
                .catch(function () { shareBtn.disabled = false; });
        }, function (err) {
            alert('Impossible d\'obtenir votre position: ' + err.message);
            shareBtn.disabled = false;
            shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position';
        }, { enableHighAccuracy: true, timeout: 10000 });
    });

    // — Manual pin mode —
    // User clicks "Épingler manuellement" → the cursor becomes a crosshair and
    // any click on the map drops a draggable preview marker. Confirm posts the
    // lat/lng + current TTL/label to /map/pin, same backend as geolocation.
    var manualBtn     = document.getElementById('mapManualBtn');
    var manualPanel   = document.getElementById('mapManualPanel');
    var manualHint    = document.getElementById('mapManualHint');
    var manualConfirm = document.getElementById('mapManualConfirm');
    var manualCancel  = document.getElementById('mapManualCancel');
    var previewMarker = null;
    var manualActive  = false;

    function setManualMode(on) {
        manualActive = on;
        manualPanel.classList.toggle('d-none', !on);
        document.getElementById('map').style.cursor = on ? 'crosshair' : '';
        manualBtn.classList.toggle('active', on);
        if (!on && previewMarker) {
            map.removeLayer(previewMarker);
            previewMarker = null;
        }
        if (!on) {
            manualConfirm.disabled = true;
            manualHint.textContent = 'Cliquez sur la carte pour placer votre épingle.';
        }
    }

    manualBtn.addEventListener('click', function () { setManualMode(!manualActive); });
    manualCancel.addEventListener('click', function () { setManualMode(false); });

    map.on('click', function (e) {
        if (!manualActive) return;
        var latlng = e.latlng;
        if (!previewMarker) {
            previewMarker = L.marker(latlng, {
                draggable: true,
                icon: buildAvatarIcon({ username: 'moi', photo: null, isMine: true })
            }).addTo(map);
            previewMarker.on('dragend', function () {
                var p = previewMarker.getLatLng();
                manualHint.textContent = 'Position: ' + p.lat.toFixed(5) + ', ' + p.lng.toFixed(5) + ' (glissez pour ajuster).';
            });
        } else {
            previewMarker.setLatLng(latlng);
        }
        manualConfirm.disabled = false;
        manualHint.textContent = 'Position: ' + latlng.lat.toFixed(5) + ', ' + latlng.lng.toFixed(5) + ' (glissez pour ajuster).';
    });

    manualConfirm.addEventListener('click', function () {
        if (!previewMarker) return;
        var p = previewMarker.getLatLng();
        var ttl = document.getElementById('mapTtl').value;
        var label = document.getElementById('mapLabel').value;
        manualConfirm.disabled = true;
        manualConfirm.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Envoi...';
        var body = new URLSearchParams();
        body.append('_token', CSRF);
        body.append('lat', p.lat);
        body.append('lng', p.lng);
        body.append('ttlHours', ttl);
        body.append('label', label);
        fetch(PIN_URL, { method: 'POST', body: body, credentials: 'same-origin' })
            .then(function (r) { return r.json(); })
            .then(function (j) {
                if (j.ok) { window.location.reload(); }
                else {
                    alert('Erreur: ' + (j.error || 'inconnue'));
                    manualConfirm.disabled = false;
                    manualConfirm.innerHTML = '<i class="fas fa-check me-1"></i>Confirmer cette position';
                }
            })
            .catch(function () {
                manualConfirm.disabled = false;
                manualConfirm.innerHTML = '<i class="fas fa-check me-1"></i>Confirmer cette position';
            });
    });

    // — Unpin —
    var unpinBtn = document.getElementById('mapUnpinBtn');
    if (unpinBtn) {
        unpinBtn.addEventListener('click', function () {
            if (!confirm('Retirer votre position de la carte ?')) return;
            var body = new URLSearchParams();
            body.append('_token', CSRF);
            fetch(UNPIN_URL, { method: 'POST', body: body, credentials: 'same-origin' })
                .then(function (r) { return r.json(); })
                .then(function (j) { if (j.ok) window.location.reload(); });
        });
    }
})();
</script>
{% endblock %}
