<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ title|default('Admin') }}{% endblock %}</title>
    <link rel="icon" type="image/png" href="/assets/java/trans_bg.png">
    <link rel="stylesheet" href="/app.css">
    <link rel="stylesheet" href="/currency.css">
    <link rel="stylesheet" href="/admin.css">
    {% for stylesheet in stylesheets|default([]) %}
        <link rel="stylesheet" href="{{ stylesheet }}">
    {% endfor %}
</head>
<body class="{% block body_class %}{{ pageClass|default('admin-page-body') }}{% endblock %}">
    {% block body %}{% endblock %}
    <script src="/currency.js"></script>
</body>
</html>
