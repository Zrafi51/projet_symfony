{% extends 'base.html.twig' %}

{% block title %}Carte - Forum Voyage{% endblock %}

{% block body %}
{# The map is rendered by the symfony/ux-leaflet-map bundle. The Twig
   ux_map() helper outputs the wrapper div + a Stimulus controller that
   creates the Leaflet instance from the server-built Map object. We listen
   to the bundle's `ux:map:connect` event to (1) replace the default markers
   with our avatar bubbles and (2) wire up manual-pin clicks. #}

<div class="map-wrapper">
    <div class="map-header d-flex align-items-center justify-content-between px-3 py-2 bg-white border-bottom">
        <a href="{{ path('app_forum') }}" class="btn btn-link text-muted p-0">
            <i class="fas fa-arrow-left fs-5"></i>
        </a>
        <h5 class="m-0"><i class="fas fa-map-location-dot me-2 text-primary"></i>Carte des amis</h5>
        <span></span>
    </div>

    <div id="mapStatusBanner" class="map-status px-3 py-2 small text-center">
        {% if mine %}
            <span class="text-success">
                <i class="fas fa-location-dot me-1"></i>
                Votre position est partagée jusqu'à
                <strong>{{ mine.expiresAt|date('H:i') }}</strong>
                ({{ mine.expiresAt|date('d/m/Y') }})
            </span>
            <button type="button" class="btn btn-sm btn-outline-danger ms-2" id="mapUnpinBtn">
                <i class="fas fa-xmark me-1"></i>Retirer
            </button>
        {% else %}
            <span class="text-muted">
                <i class="fas fa-circle-info me-1"></i>
                Localisation non partagée — appuyez sur « Partager ma position » pour apparaître sur la carte.
            </span>
        {% endif %}
    </div>

    {# The bundle's helper. The id lets our JS scope the connect listener. #}
    {{ ux_map(map, {id: 'map', style: 'width:100%;height:62vh;min-height:420px'}) }}

    <div class="map-compose border-top bg-white p-3">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <label class="form-label small text-muted mb-1">Durée</label>
                <select class="form-select form-select-sm" id="mapTtl">
                    <option value="1">1 heure</option>
                    <option value="4" selected>4 heures</option>
                    <option value="8">8 heures</option>
                    <option value="24">24 heures</option>
                </select>
            </div>
            <div class="col-md-5">
                <label class="form-label small text-muted mb-1">Note (optionnel)</label>
                <input type="text" class="form-control form-control-sm" id="mapLabel"
                       maxlength="120" placeholder="Ex: Café du coin ☕">
            </div>
            <div class="col-md-3 d-grid gap-1">
                <label class="form-label small text-muted mb-1 d-none d-md-block">&nbsp;</label>
                <button type="button" class="btn btn-primary btn-sm" id="mapShareBtn">
                    <i class="fas fa-location-crosshairs me-1"></i>Partager ma position
                </button>
                <button type="button" class="btn btn-outline-primary btn-sm" id="mapManualBtn">
                    <i class="fas fa-hand-pointer me-1"></i>Épingler manuellement
                </button>
            </div>
        </div>
        <div id="mapManualPanel" class="mt-2 d-none">
            <div class="alert alert-info py-2 mb-2 small d-flex align-items-center gap-2">
                <i class="fas fa-circle-info"></i>
                <span id="mapManualHint">Cliquez sur la carte pour placer votre épingle.</span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-success btn-sm" id="mapManualConfirm" disabled>
                    <i class="fas fa-check me-1"></i>Confirmer cette position
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="mapManualCancel">
                    <i class="fas fa-xmark me-1"></i>Annuler
                </button>
            </div>
        </div>
        <div class="small text-muted mt-2">
            <i class="fas fa-shield-halved me-1"></i>
            Seules les personnes que vous suivez peuvent voir votre pin.
        </div>
    </div>
</div>

<style>
.map-wrapper {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 2px 10px rgba(0,0,0,.08);
}
.map-status { background: #f8f9fa; }
.map-avatar-marker {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 3px solid #1877f2;
    background: #fff;
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0,0,0,.25);
}
.map-avatar-marker img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.map-avatar-marker.mine { border-color: #dc3545; }
.map-avatar-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #6c757d;
    color: #fff;
    font-weight: bold;
    font-size: 1.1rem;
}
</style>

<script type="module">
// Pull Leaflet from the importmap so we can build divIcons that match the
// look of the previous custom markers, and replace the bundle's default
// pins on connect.
import L from 'leaflet';

const CSRF       = {{ csrf_token('map_pin')|json_encode|raw }};
const PIN_URL    = {{ path('app_map_pin')|json_encode|raw }};
const UNPIN_URL  = {{ path('app_map_unpin')|json_encode|raw }};
const PHOTO_BASE = {{ asset('uploads/profiles/')|json_encode|raw }};

function buildAvatarIcon(extra) {
    const inner = extra && extra.photo
        ? `<img src="${PHOTO_BASE}${encodeURIComponent(extra.photo)}" alt="">`
        : `<div class="map-avatar-fallback">${(extra && extra.username || '?').charAt(0).toUpperCase()}</div>`;
    const klass = 'map-avatar-marker' + (extra && extra.isMine ? ' mine' : '');
    return L.divIcon({
        className: '',
        html: `<div class="${klass}">${inner}</div>`,
        iconSize: [44, 44],
        iconAnchor: [22, 22],
        popupAnchor: [0, -20],
    });
}

let leafletMap = null;
let leafletMarkers = [];
let previewMarker = null;
let manualActive = false;

const mapEl = document.getElementById('map');

// Fired by the ux-leaflet-map Stimulus controller once the Leaflet map and
// markers exist. We swap the marker icons for our avatar divIcons.
mapEl.addEventListener('ux:map:connect', (event) => {
    leafletMap = event.detail.map;
    leafletMarkers = event.detail.markers;

    // event.detail.markers is the live list of L.Marker instances created
    // by the bundle, in the same order as the server-side Map::addMarker
    // calls. We pair them up with our `extra` payload via the bundle's
    // `markersValue` (read from the controller element).
    // The Stimulus controller id is `@symfony/ux-leaflet-map/map` which renders
    // as `data-symfony--ux-leaflet-map--map-markers-value` → camelCase below.
    const markersDef = JSON.parse(mapEl.dataset.symfonyUxLeafletMapMapMarkersValue || '[]');
    leafletMarkers.forEach((m, i) => {
        const def = markersDef[i] || {};
        m.setIcon(buildAvatarIcon(def.extra || {}));
    });

    // Manual-pin clicks — only react when the user has activated the mode.
    leafletMap.on('click', (e) => {
        if (!manualActive) return;
        if (!previewMarker) {
            previewMarker = L.marker(e.latlng, {
                draggable: true,
                icon: buildAvatarIcon({ username: 'moi', photo: null, isMine: true }),
            }).addTo(leafletMap);
            previewMarker.on('dragend', () => {
                const p = previewMarker.getLatLng();
                manualHint.textContent = `Position: ${p.lat.toFixed(5)}, ${p.lng.toFixed(5)} (glissez pour ajuster).`;
            });
        } else {
            previewMarker.setLatLng(e.latlng);
        }
        manualConfirm.disabled = false;
        manualHint.textContent = `Position: ${e.latlng.lat.toFixed(5)}, ${e.latlng.lng.toFixed(5)} (glissez pour ajuster).`;
    });
});

// — Share location —
const shareBtn = document.getElementById('mapShareBtn');
shareBtn.addEventListener('click', () => {
    if (!navigator.geolocation) {
        alert('La géolocalisation n\'est pas disponible sur votre navigateur.');
        return;
    }
    shareBtn.disabled = true;
    shareBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Localisation...';
    navigator.geolocation.getCurrentPosition((pos) => {
        const body = new URLSearchParams();
        body.append('_token', CSRF);
        body.append('lat', pos.coords.latitude);
        body.append('lng', pos.coords.longitude);
        body.append('ttlHours', document.getElementById('mapTtl').value);
        body.append('label', document.getElementById('mapLabel').value);
        fetch(PIN_URL, { method: 'POST', body, credentials: 'same-origin' })
            .then((r) => r.json())
            .then((j) => {
                if (j.ok) { window.location.reload(); }
                else {
                    alert('Erreur: ' + (j.error || 'inconnue'));
                    shareBtn.disabled = false;
                    shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position';
                }
            })
            .catch(() => { shareBtn.disabled = false; });
    }, (err) => {
        alert('Impossible d\'obtenir votre position: ' + err.message);
        shareBtn.disabled = false;
        shareBtn.innerHTML = '<i class="fas fa-location-crosshairs me-1"></i>Partager ma position';
    }, { enableHighAccuracy: true, timeout: 10000 });
});

// — Manual pin mode —
const manualBtn     = document.getElementById('mapManualBtn');
const manualPanel   = document.getElementById('mapManualPanel');
const manualHint    = document.getElementById('mapManualHint');
const manualConfirm = document.getElementById('mapManualConfirm');
const manualCancel  = document.getElementById('mapManualCancel');

function setManualMode(on) {
    manualActive = on;
    manualPanel.classList.toggle('d-none', !on);
    mapEl.style.cursor = on ? 'crosshair' : '';
    manualBtn.classList.toggle('active', on);
    if (!on && previewMarker && leafletMap) {
        leafletMap.removeLayer(previewMarker);
        previewMarker = null;
    }
    if (!on) {
        manualConfirm.disabled = true;
        manualHint.textContent = 'Cliquez sur la carte pour placer votre épingle.';
    }
}

manualBtn.addEventListener('click', () => setManualMode(!manualActive));
manualCancel.addEventListener('click', () => setManualMode(false));

manualConfirm.addEventListener('click', () => {
    if (!previewMarker) return;
    const p = previewMarker.getLatLng();
    manualConfirm.disabled = true;
    manualConfirm.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Envoi...';
    const body = new URLSearchParams();
    body.append('_token', CSRF);
    body.append('lat', p.lat);
    body.append('lng', p.lng);
    body.append('ttlHours', document.getElementById('mapTtl').value);
    body.append('label', document.getElementById('mapLabel').value);
    fetch(PIN_URL, { method: 'POST', body, credentials: 'same-origin' })
        .then((r) => r.json())
        .then((j) => {
            if (j.ok) { window.location.reload(); }
            else {
                alert('Erreur: ' + (j.error || 'inconnue'));
                manualConfirm.disabled = false;
                manualConfirm.innerHTML = '<i class="fas fa-check me-1"></i>Confirmer cette position';
            }
        })
        .catch(() => {
            manualConfirm.disabled = false;
            manualConfirm.innerHTML = '<i class="fas fa-check me-1"></i>Confirmer cette position';
        });
});

// — Unpin —
const unpinBtn = document.getElementById('mapUnpinBtn');
if (unpinBtn) {
    unpinBtn.addEventListener('click', () => {
        if (!confirm('Retirer votre position de la carte ?')) return;
        const body = new URLSearchParams();
        body.append('_token', CSRF);
        fetch(UNPIN_URL, { method: 'POST', body, credentials: 'same-origin' })
            .then((r) => r.json())
            .then((j) => { if (j.ok) window.location.reload(); });
    });
}
</script>
{% endblock %}
