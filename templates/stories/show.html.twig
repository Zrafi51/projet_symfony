{% extends 'base.html.twig' %}

{% block title %}Story de {{ author }} - Forum Voyage{% endblock %}

{% block body %}
{#
    Story viewer. Can be displayed two ways:

      1. **Standalone page** — direct navigation to /story/user/{username}.
         Covers the full viewport; navbar is hidden via body.story-viewing.
      2. **Embedded inside a modal iframe** — opened from the feed or a
         profile via JS. In that case the parent page remains visible around
         the phone frame; close / delete actions talk to the parent with
         postMessage instead of navigating.

    Playback rules:
      - Images → 15 s each (auto-advance)
      - Videos → the video's own duration (auto-advance on 'ended')
      - Music (optional) → plays from `music_start` offset, cut to the story
        duration so it exactly matches the length of the story.
#}
<div class="story-viewer" data-author="{{ author }}" data-return-url="{{ returnUrl }}">
    <div class="story-viewer-inner">

        {# Progress bars — one per story, filled as it plays. #}
        <div class="story-progress-bar">
            {% for s in stories %}
                <div class="story-progress-seg" data-idx="{{ loop.index0 }}">
                    <div class="story-progress-fill"></div>
                </div>
            {% endfor %}
        </div>

        {# Header — author + close + delete (owner only). #}
        <div class="story-header d-flex align-items-center gap-2">
            {% if authorPhoto %}
                <img src="{{ asset('uploads/profiles/' ~ authorPhoto) }}"
                     class="rounded-circle" width="36" height="36"
                     style="object-fit:cover;border:2px solid #fff;" alt="{{ author }}">
            {% else %}
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-secondary text-white"
                     style="width:36px;height:36px;border:2px solid #fff;">
                    {{ author|first|upper }}
                </div>
            {% endif %}
            <div class="text-white flex-grow-1">
                <div class="fw-semibold small">{{ author }}</div>
                <div class="small opacity-75 story-elapsed">il y a quelques instants</div>
            </div>

            {% if isOwner %}
                <form method="post" action="" class="story-delete-form m-0"
                      onsubmit="return confirm('Supprimer cette story ?');">
                    <input type="hidden" name="_token" value="" class="story-delete-token">
                    <input type="hidden" name="return" value="{{ app.request.query.get('return')|default('') }}">
                    <button type="submit" class="btn btn-sm text-white story-btn" title="Supprimer">
                        <i class="fas fa-trash"></i>
                    </button>
                </form>
            {% endif %}
            <a href="{{ returnUrl }}" class="btn btn-sm text-white story-btn story-close-btn" title="Fermer">
                <i class="fas fa-times fa-lg"></i>
            </a>
        </div>

        {# Media slots — exactly one is visible at a time, controlled by JS. #}
        <div class="story-media-stage">
            {% for s in stories %}
                <div class="story-slide {{ loop.first ? 'active' : '' }}"
                     data-idx="{{ loop.index0 }}"
                     data-story-id="{{ s.id }}"
                     data-kind="{{ s.mediaType }}"
                     data-created-ts="{{ s.createdAt.timestamp }}"
                     data-music-url="{{ s.music ? asset('uploads/music/' ~ s.music.filename) : '' }}"
                     data-music-title="{{ s.music ? s.music.displayName : '' }}"
                     data-music-start="{{ s.musicStart|default(0) }}"
                     data-delete-token="{{ csrf_token('story_delete_' ~ s.id) }}"
                     data-delete-url="{{ path('app_story_delete', {id: s.id}) }}"
                     data-view-url="{{ path('app_story_view_record', {id: s.id}) }}"
                     data-like-url="{{ path('app_story_like_toggle', {id: s.id}) }}"
                     data-reply-url="{{ path('app_story_reply', {id: s.id}) }}"
                     data-reply-token="{{ csrf_token('story_reply_' ~ s.id) }}"
                     data-liked="{{ (likedMap[s.id] ?? false) ? '1' : '0' }}"
                     data-like-count="{{ likeCount[s.id] ?? 0 }}">
                    {% if s.isImage %}
                        <img src="{{ asset('uploads/stories/' ~ s.filename) }}" alt="story">
                    {% else %}
                        <video src="{{ asset('uploads/stories/' ~ s.filename) }}"
                               playsinline preload="metadata"></video>
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        {# Music bar (hidden if the current story has no music). #}
        <div class="story-music-bar d-none">
            <i class="fas fa-music me-2"></i><span class="story-music-title"></span>
        </div>

        {# Invisible nav zones — left 1/3 goes back, right 2/3 advances. #}
        <div class="story-nav story-nav-prev" role="button" aria-label="Précédent"></div>
        <div class="story-nav story-nav-next" role="button" aria-label="Suivant"></div>

        {# Bottom bar — Instagram-style: reply input (only for viewers, not
           the owner) + heart button in the corner. The owner instead sees a
           viewer count ("X vues"). #}
        {% if not isOwner %}
            <form class="story-bottom-bar d-flex align-items-center gap-2" autocomplete="off" novalidate>
                <input type="text" class="story-reply-input form-control form-control-sm"
                       placeholder="Envoyer un message..." maxlength="500">
                <button type="button" class="story-heart-btn" aria-label="J'aime" title="J'aime">
                    <i class="far fa-heart"></i>
                </button>
                <button type="button" class="story-send-btn" aria-label="Envoyer" title="Envoyer">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </form>
            <div class="story-reply-toast d-none" role="alert"></div>
        {% else %}
            <div class="story-owner-footer text-white small">
                <i class="fas fa-eye me-1"></i><span class="story-view-count">0</span> vues
                &middot;
                <i class="fas fa-heart me-1 text-danger"></i><span class="story-like-count">0</span>
            </div>
        {% endif %}

    </div>
    {# One shared <audio> — src swaps per-slide so music doesn't restart
       when the same track is reused on consecutive stories. #}
    <audio class="story-audio" playsinline></audio>
</div>

<style>
/* Viewer is a full-viewport overlay — hide the page chrome so close/delete
   buttons are always visible on every screen size. */
body.story-viewing .navbar,
body.story-viewing .flash-messages,
body.story-viewing > nav { display: none !important; }
body.story-viewing { overflow: hidden; }

/* When embedded in the modal iframe, the parent page paints the dark
   backdrop *around* the phone frame — so we drop our own background fill
   to avoid a double-dim and let the rounded frame float cleanly. */
body.story-embedded { background: transparent !important; }
body.story-embedded .story-viewer { background: transparent; }

.story-viewer {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Safe-area padding for iOS notch. */
    padding: env(safe-area-inset-top, 0) 0 env(safe-area-inset-bottom, 0) 0;
}
.story-viewer-inner {
    position: relative;
    width: 100vw;
    height: 100vh;
    max-width: 500px;    /* cap on large screens so it doesn't feel stretched */
    max-height: 100vh;
    background: #111;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,.6);
}
@media (min-width: 600px) {
    .story-viewer-inner {
        border-radius: 12px;
        height: 95vh;
        max-height: 860px;
    }
}
.story-progress-bar {
    position: absolute;
    top: 8px; left: 8px; right: 8px;
    display: flex;
    gap: 4px;
    z-index: 5;
}
.story-progress-seg {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,.35);
    border-radius: 2px;
    overflow: hidden;
}
.story-progress-fill {
    height: 100%;
    width: 0;
    background: #fff;
    transition: width .05s linear;
}
.story-header {
    position: absolute;
    top: 18px; left: 8px; right: 8px;
    z-index: 6;
    padding: 4px 8px;
}
.story-btn {
    background: rgba(0,0,0,.45);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
}
.story-btn:hover { background: rgba(0,0,0,.7); color: #fff; }
.story-media-stage {
    position: absolute;
    inset: 0;
}
.story-slide {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: #000;
}
.story-slide.active { display: flex; }
.story-slide img, .story-slide video {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: contain;
}
.story-music-bar {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,.55);
    color: #fff;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: .8rem;
    z-index: 4;
    max-width: 80%;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.story-nav {
    position: absolute;
    top: 70px;
    bottom: 50px;
    z-index: 3;
    cursor: pointer;
}
.story-nav-prev { left: 0; width: 33%; }
.story-nav-next { left: 33%; right: 0; }

/* ————— Bottom bar (reply + heart) ————— */
.story-bottom-bar {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    z-index: 7;
    padding: 6px;
    gap: 8px;
}
.story-reply-input {
    flex: 1;
    background: rgba(255,255,255,.15);
    color: #fff;
    border: 1px solid rgba(255,255,255,.4);
    border-radius: 22px;
    padding: 8px 14px;
    font-size: .9rem;
    height: 42px;
}
.story-reply-input::placeholder { color: rgba(255,255,255,.75); }
.story-reply-input:focus {
    background: rgba(255,255,255,.25);
    color: #fff;
    border-color: #fff;
    outline: none;
    box-shadow: none;
}
.story-heart-btn, .story-send-btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 0;
    background: rgba(0,0,0,.4);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
}
.story-heart-btn:hover, .story-send-btn:hover { background: rgba(0,0,0,.65); }
/* Liked state — red fill heart. */
.story-heart-btn.is-liked { color: #ff3b5c; background: rgba(255,255,255,.15); }
.story-heart-btn.is-liked i { font-weight: 900; }
/* Heart "pop" animation when the user toggles on. */
@keyframes storyHeartPop {
    0%   { transform: scale(1); }
    40%  { transform: scale(1.35); }
    100% { transform: scale(1); }
}
.story-heart-btn.pop { animation: storyHeartPop .35s ease; }

.story-reply-toast {
    position: absolute;
    left: 50%;
    bottom: 70px;
    transform: translateX(-50%);
    background: rgba(0,0,0,.85);
    color: #fff;
    padding: 8px 14px;
    border-radius: 18px;
    font-size: .85rem;
    z-index: 8;
    max-width: 85%;
    text-align: center;
}

.story-owner-footer {
    position: absolute;
    left: 14px; bottom: 14px;
    z-index: 7;
    background: rgba(0,0,0,.45);
    padding: 6px 12px;
    border-radius: 16px;
}
</style>

<script>
(function () {
    // Are we running inside the story modal iframe? If yes, the parent page
    // is responsible for the dark backdrop around us, so we drop the black
    // fill and talk back via postMessage instead of navigating on close.
    var embedded = (window !== window.top);
    if (embedded) {
        document.body.classList.add('story-embedded');
    }
    // Tag the body so the CSS above can hide the navbar on this page only.
    document.body.classList.add('story-viewing');

    function closeViewer() {
        stopAudio();
        if (embedded) {
            try { window.parent.postMessage({ type: 'story-close' }, '*'); } catch (_) {}
        } else {
            window.location.href = returnUrl;
        }
    }

    var viewer  = document.querySelector('.story-viewer');
    if (!viewer) return;
    var returnUrl = viewer.dataset.returnUrl || "{{ path('app_forum') }}";
    var slides  = Array.prototype.slice.call(viewer.querySelectorAll('.story-slide'));
    var segs    = Array.prototype.slice.call(viewer.querySelectorAll('.story-progress-seg .story-progress-fill'));
    var audio   = viewer.querySelector('.story-audio');
    var musicBar = viewer.querySelector('.story-music-bar');
    var musicTitle = viewer.querySelector('.story-music-title');
    var elapsed = viewer.querySelector('.story-elapsed');
    var deleteForm  = viewer.querySelector('.story-delete-form');
    var deleteToken = viewer.querySelector('.story-delete-token');

    // ——— Story interactions (heart, reply, view-recording) ———
    var heartBtn   = viewer.querySelector('.story-heart-btn');
    var replyInput = viewer.querySelector('.story-reply-input');
    var sendBtn    = viewer.querySelector('.story-send-btn');
    var toast      = viewer.querySelector('.story-reply-toast');
    var ownerFooter = viewer.querySelector('.story-owner-footer');
    var ownerLikeCount = viewer.querySelector('.story-like-count');

    function showToast(msg, isError) {
        if (!toast) return;
        toast.textContent = msg;
        toast.classList.remove('d-none');
        toast.style.background = isError ? 'rgba(176,0,32,.92)' : 'rgba(0,0,0,.85)';
        setTimeout(function () { toast.classList.add('d-none'); }, 2200);
    }

    function paintHeart(slide) {
        if (!heartBtn) return;
        var liked = slide.dataset.liked === '1';
        var icon  = heartBtn.querySelector('i');
        heartBtn.classList.toggle('is-liked', liked);
        if (icon) icon.className = liked ? 'fas fa-heart' : 'far fa-heart';
    }

    function paintOwnerFooter(slide) {
        if (!ownerFooter) return;
        if (ownerLikeCount) ownerLikeCount.textContent = slide.dataset.likeCount || '0';
        var vc = ownerFooter.querySelector('.story-view-count');
        // View-count isn't pushed per-slide yet — placeholder stays '—' until
        // we add a per-story `views` counter. (The count is recorded, just
        // not exposed here.) Set to blank so we don't lie.
        if (vc && !vc.dataset.loaded) { vc.textContent = '—'; }
    }

    // Record that the current user has opened this story. Idempotent on the
    // server, but we also dedupe client-side so rapid next/prev doesn't spam.
    var recorded = {};
    function recordView(slide) {
        var url = slide.dataset.viewUrl;
        var sid = slide.dataset.storyId;
        if (!url || !sid || recorded[sid]) return;
        recorded[sid] = true;
        fetch(url, {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).catch(function () {});
    }

    // Heart button: toggle like/unlike on the CURRENT slide.
    if (heartBtn) {
        heartBtn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            var slide = slides[current];
            var url = slide.dataset.likeUrl;
            if (!url) return;
            fetch(url, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                slide.dataset.liked = data.liked ? '1' : '0';
                slide.dataset.likeCount = String(data.count);
                paintHeart(slide);
                if (data.liked) {
                    heartBtn.classList.remove('pop');
                    void heartBtn.offsetWidth;  // restart animation
                    heartBtn.classList.add('pop');
                }
            })
            .catch(function () { showToast('Erreur réseau', true); });
        });
    }

    // Reply input: Enter or send button POSTs, bubble shows in the DM thread
    // the next time the user opens it. The viewer stays on the story.
    function sendReply() {
        if (!replyInput) return;
        var slide = slides[current];
        var url   = slide.dataset.replyUrl;
        var token = slide.dataset.replyToken;
        var content = (replyInput.value || '').trim();
        if (!content) return;
        if (sendBtn) sendBtn.disabled = true;
        var fd = new FormData();
        fd.append('_token', token);
        fd.append('content', content);
        fetch(url, {
            method: 'POST',
            body: fd,
            credentials: 'same-origin',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
        .then(function (res) {
            if (!res.ok) {
                showToast(res.data.error || 'Erreur à l\'envoi', true);
            } else {
                replyInput.value = '';
                showToast('Réponse envoyée ✓');
            }
        })
        .catch(function () { showToast('Erreur réseau', true); })
        .finally(function () { if (sendBtn) sendBtn.disabled = false; });
    }
    if (sendBtn) sendBtn.addEventListener('click', function (e) {
        e.preventDefault();
        sendReply();
    });
    if (replyInput) {
        replyInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); sendReply(); }
        });
        // Block arrow-keys on the reply input from bubbling up to the global
        // next/prev handlers — otherwise typing becomes story-navigation.
        replyInput.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' || e.key === ' ') {
                e.stopPropagation();
            }
        });
    }

    if (!slides.length) return;

    var IMAGE_MS = 15000; // images auto-advance after 15 s (per user spec)
    var current  = 0;
    var raf      = null;
    var startTs  = 0;
    var durationMs = IMAGE_MS;
    var currentMedia = null;
    var audioStopTimer = null;

    function fmtElapsed(createdTs) {
        var now = Math.floor(Date.now() / 1000);
        var diff = Math.max(0, now - createdTs);
        if (diff < 60)    return 'il y a ' + diff + 's';
        if (diff < 3600)  return 'il y a ' + Math.floor(diff / 60) + 'min';
        return 'il y a ' + Math.floor(diff / 3600) + 'h';
    }

    function stopAudio() {
        if (audioStopTimer) { clearTimeout(audioStopTimer); audioStopTimer = null; }
        try { audio.pause(); } catch (_) {}
    }

    function playMusicForDuration(url, startSec, durSec) {
        // Swap src only if different so track doesn't restart when reused
        // on consecutive slides.
        if (audio.src !== url) { audio.src = url; }
        audio.currentTime = Math.max(0, startSec || 0);
        audio.play().catch(function () { /* autoplay blocked — ignore */ });
        // Hard-stop after the exact slide duration so music never overruns.
        if (audioStopTimer) clearTimeout(audioStopTimer);
        audioStopTimer = setTimeout(function () {
            try { audio.pause(); } catch (_) {}
        }, Math.max(500, durSec * 1000));
    }

    function showSlide(i) {
        if (i < 0) i = 0;
        if (i >= slides.length) { closeViewer(); return; }
        current = i;

        // Progress bars: before=full, current=0, after=0.
        segs.forEach(function (fill, idx) {
            fill.style.transition = 'none';
            fill.style.width = idx < i ? '100%' : '0%';
        });
        void segs[i].offsetWidth;
        segs[i].style.transition = 'width .05s linear';

        slides.forEach(function (s) { s.classList.remove('active'); });
        var slide = slides[i];
        slide.classList.add('active');

        // Record the view (once per story), and refresh the heart + owner
        // footer to reflect this specific story's state.
        recordView(slide);
        paintHeart(slide);
        paintOwnerFooter(slide);

        if (elapsed) {
            elapsed.textContent = fmtElapsed(parseInt(slide.dataset.createdTs || '0', 10));
        }
        if (deleteForm && deleteToken) {
            deleteForm.action = slide.dataset.deleteUrl;
            deleteToken.value = slide.dataset.deleteToken;
        }

        stopTimer();
        var musicUrl   = slide.dataset.musicUrl || '';
        var musicStart = parseFloat(slide.dataset.musicStart || '0') || 0;

        if (slide.dataset.kind === 'video') {
            currentMedia = slide.querySelector('video');
            currentMedia.currentTime = 0;
            // Mute the video's own track when a music clip is attached so
            // they don't overlap; otherwise unmute so user hears the video.
            currentMedia.muted = !!musicUrl;
            currentMedia.onloadedmetadata = function () {
                durationMs = Math.max(1000, (currentMedia.duration || 5) * 1000);
                startProgress();
                if (musicUrl) {
                    musicBar.classList.remove('d-none');
                    musicTitle.textContent = slide.dataset.musicTitle || '';
                    playMusicForDuration(musicUrl, musicStart, durationMs / 1000);
                } else {
                    stopAudio();
                    musicBar.classList.add('d-none');
                }
            };
            currentMedia.onended = function () { showSlide(current + 1); };
            currentMedia.play().catch(function () {});
            if (currentMedia.readyState >= 1) {
                currentMedia.onloadedmetadata();
            }
        } else {
            currentMedia = null;
            durationMs = IMAGE_MS;
            startProgress();
            if (musicUrl) {
                musicBar.classList.remove('d-none');
                musicTitle.textContent = slide.dataset.musicTitle || '';
                playMusicForDuration(musicUrl, musicStart, IMAGE_MS / 1000);
            } else {
                stopAudio();
                musicBar.classList.add('d-none');
            }
        }
    }

    function startProgress() {
        startTs = performance.now();
        var fill = segs[current];
        (function tick(now) {
            var pct = Math.min(100, ((now - startTs) / durationMs) * 100);
            fill.style.width = pct + '%';
            if (pct >= 100) {
                raf = null;
                showSlide(current + 1);
                return;
            }
            raf = requestAnimationFrame(tick);
        })(performance.now());
    }

    function stopTimer() {
        if (raf) { cancelAnimationFrame(raf); raf = null; }
        if (currentMedia) {
            try { currentMedia.pause(); } catch (_) {}
            currentMedia.onended = null;
            currentMedia.onloadedmetadata = null;
        }
    }

    viewer.querySelector('.story-nav-next').addEventListener('click', function () { showSlide(current + 1); });
    viewer.querySelector('.story-nav-prev').addEventListener('click', function () { showSlide(Math.max(0, current - 1)); });

    // Hijack the close link so we can postMessage instead of navigating when
    // we're inside the modal iframe.
    var closeLink = viewer.querySelector('.story-close-btn');
    if (closeLink) {
        closeLink.addEventListener('click', function (e) {
            e.preventDefault();
            closeViewer();
        });
    }

    // Inside the iframe, the delete form would normally POST and then the
    // server redirects to returnUrl — which would load the feed *inside* the
    // iframe. Intercept: fire the request via fetch, then ask the parent to
    // close the modal and reload its stories bar.
    if (embedded && deleteForm) {
        deleteForm.addEventListener('submit', function (e) {
            e.preventDefault();
            if (!window.confirm('Supprimer cette story ?')) return;
            var fd = new FormData(deleteForm);
            fetch(deleteForm.action, {
                method: 'POST',
                body: fd,
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).finally(function () {
                try { window.parent.postMessage({ type: 'story-deleted' }, '*'); } catch (_) {}
            });
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); showSlide(current + 1); }
        else if (e.key === 'ArrowLeft')              { e.preventDefault(); showSlide(Math.max(0, current - 1)); }
        else if (e.key === 'Escape')                 { closeViewer(); }
    });

    // Restore navbar visibility when leaving this page.
    window.addEventListener('beforeunload', function () {
        document.body.classList.remove('story-viewing');
    });

    showSlide(0);
})();
</script>
{% endblock %}
