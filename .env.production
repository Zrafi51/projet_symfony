###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

###> doctrine/doctrine-bundle ###
# Railway fournit DATABASE_URL automatiquement via le service MySQL/MariaDB
DATABASE_URL="mysql://${MYSQLUSER}:${MYSQLPASSWORD}@${MYSQLHOST}:${MYSQLPORT}/${MYSQLDATABASE}?serverVersion=8.0&charset=utf8mb4"

###< doctrine/doctrine-bundle ###
###< symfony/framework-bundle ###

EASY_TRAVEL_AGENT_URL=http://localhost:8081
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
