{% extends 'auth-layout.html.twig' %}

{% block content %}
<section class="auth-card">
    <div class="auth-visual">
        <img src="/assets/java/trans_bg.png" alt="EasyTravel">
    </div>

    <div class="auth-panel">
        <div class="auth-panel__header">
            <h1>Inscription</h1>
            <p>Creez votre compte gratuitement</p>
        </div>

        <form class="auth-form" method="post" action="/sign-up">
            <div class="auth-grid">
                <label>
                    <span>Prenom</span>
                    <input class="{{ 'prenom' in fieldErrors|default([]) ? 'auth-input-invalid' : '' }}" 
                           type="text" 
                           name="prenom" 
                           value="{{ form.prenom|default('') }}" 
                           placeholder="Votre prenom" 
                           required>
                </label>

                <label>
                    <span>Nom</span>
                    <input class="{{ 'nom' in fieldErrors|default([]) ? 'auth-input-invalid' : '' }}" 
                           type="text" 
                           name="nom" 
                           value="{{ form.nom|default('') }}" 
                           placeholder="Votre nom" 
                           required>
                </label>
            </div>

            <label>
                <span>Email</span>
                <input class="{{ 'email' in fieldErrors|default([]) ? 'auth-input-invalid' : '' }}" 
                       type="email" 
                       name="email" 
                       value="{{ form.email|default('') }}" 
                       placeholder="exemple@email.com" 
                       required>
            </label>

            <label>
                <span>Mot de passe</span>
                <input class="{{ 'password' in fieldErrors|default([]) ? 'auth-input-invalid' : '' }}" 
                       type="password" 
                       name="password" 
                       value="{{ form.password|default('') }}" 
                       placeholder="........" 
                       required>
            </label>

            <label>
                <span>Confirmer le mot de passe</span>
                <input class="{{ 'confirm_password' in fieldErrors|default([]) ? 'auth-input-invalid' : '' }}" 
                       type="password" 
                       name="confirm_password" 
                       value="{{ form.confirm_password|default('') }}" 
                       placeholder="........" 
                       required>
            </label>

            <button class="button auth-submit" type="submit">S'inscrire</button>

            {% if errorMessage is defined and errorMessage %}
                <p class="auth-feedback auth-feedback-error">{{ errorMessage }}</p>
            {% endif %}
        </form>

        <p class="auth-switch">
            Vous avez deja un compte ?
            <a href="/login">Se connecter</a>
        </p>
    </div>
</section>
{% endblock %}
