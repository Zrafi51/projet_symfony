{% extends 'social/base.html.twig' %}

{% block title %}Modifier Publication - Forum Voyage{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card shadow border-0">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-4"><i class="fas fa-edit me-2 text-primary"></i>Modifier la Publication</h3>

                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'edit-post-form', 'novalidate': 'novalidate'}}) }}
                    <input type="hidden" name="return_to" value="{{ returnTo|default('forum') }}">

                    {# ——— Description ——— #}
                    <div class="mb-3">
                        {{ form_label(form.description) }}
                        {{ form_widget(form.description) }}
                        {{ form_errors(form.description) }}
                        <div class="alert alert-danger d-none mt-2 mb-0 py-2 px-3 edit-desc-error" role="alert">
                            <i class="fas fa-exclamation-circle me-1"></i><span></span>
                        </div>
                    </div>

                    {# ——— Existing + new images, reorderable ——— #}
                    <div class="mb-3">
                        <label class="form-label fw-semibold small mb-1">Images</label>
                        <label for="editImageInput" class="upload-zone upload-zone-compact">
                            <input type="file" id="editImageInput" name="{{ form.imageFiles.vars.full_name }}"
                                   multiple class="d-none edit-image-input">
                            <div class="upload-zone-content">
                                <i class="fas fa-cloud-upload-alt fa-2x mb-2 text-primary"></i>
                                <p class="mb-1 fw-semibold small">Ajouter des images</p>
                                <small class="text-muted">Glissez-déposez pour réordonner, × pour retirer</small>
                            </div>
                        </label>
                        <div class="upload-preview-grid mt-2 edit-image-grid"></div>
                        <input type="hidden" name="image_order" class="edit-image-order" value="[]">
                    </div>

                    {# ——— Existing + new videos, reorderable ——— #}
                    <div class="mb-3">
                        <label class="form-label fw-semibold small mb-1">
                            Vidéos <span class="text-muted">(facultatif)</span>
                        </label>
                        <label for="editVideoInput" class="upload-zone upload-zone-compact edit-video-zone">
                            <input type="file" id="editVideoInput" name="{{ form.videoFiles.vars.full_name }}"
                                   multiple class="d-none edit-video-input">
                            <div class="upload-zone-content">
                                <i class="fas fa-video fa-2x mb-2 text-danger"></i>
                                <p class="mb-1 fw-semibold small">Ajouter des vidéos</p>
                                <small class="text-muted">MP4, WebM, MOV · glisser pour réordonner</small>
                            </div>
                        </label>
                        <div class="upload-preview-grid mt-2 edit-video-grid"></div>
                        <input type="hidden" name="video_order" class="edit-video-order" value="[]">
                    </div>

                    {# ——— Music ——— #}
                    <div class="mb-3">
                        <label class="form-label fw-semibold small mb-1">
                            <i class="fas fa-music me-1 text-success"></i>Musique de fond
                            <span class="text-muted">(facultatif)</span>
                        </label>
                        {{ form_widget(form.music, {'attr': {'class': 'form-select form-select-sm edit-music-select'}}) }}
                        <audio controls preload="none" class="w-100 mt-2 d-none edit-music-preview" style="height:36px;"></audio>
                    </div>

                    <div class="alert alert-danger d-none mt-3 mb-0 py-2 px-3 edit-submit-error" role="alert">
                        <i class="fas fa-exclamation-circle me-1"></i><span></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="fas fa-save me-2"></i>Enregistrer
                        </button>
                        <a href="{{ path(returnTo == 'profile' ? 'app_profile' : 'app_forum') }}" class="btn btn-outline-secondary">
                            Annuler
                        </a>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{# Existing media sent to JS so the grid is pre-populated. #}
<script id="edit-existing-images" type="application/json">{{
    post.images|map(img => {
        id: img.id,
        url: asset('uploads/posts/' ~ img.filename),
        name: img.filename,
        position: img.position
    })|json_encode|raw
}}</script>
<script id="edit-existing-videos" type="application/json">{{
    post.videos|map(vid => {
        id: vid.id,
        url: asset('uploads/videos/' ~ vid.filename),
        name: vid.filename,
        position: vid.position
    })|json_encode|raw
}}</script>

<script>
(function () {
    var form        = document.querySelector('.edit-post-form');
    if (!form) return;
    var descInput   = form.querySelector('[id$="_description"], [name$="[description]"]');
    var descError   = form.querySelector('.edit-desc-error');
    var submitError = form.querySelector('.edit-submit-error');

    // ===== Banned words (same list as the new-post card) =====
    var BANNED_WORDS = {{ banned_words()|json_encode|raw }};
    function findBanned(text) {
        if (!text) return null;
        var lower = text.toLowerCase();
        for (var i = 0; i < BANNED_WORDS.length; i++) {
            if (lower.indexOf(BANNED_WORDS[i].toLowerCase()) !== -1) return BANNED_WORDS[i];
        }
        return null;
    }
    function showDescError(msg) {
        descError.querySelector('span').textContent = msg;
        descError.classList.remove('d-none');
        if (descInput) descInput.classList.add('is-invalid');
    }
    function clearDescError() {
        descError.classList.add('d-none');
        if (descInput) descInput.classList.remove('is-invalid');
    }
    function showSubmitError(msg) {
        submitError.querySelector('span').textContent = msg;
        submitError.classList.remove('d-none');
    }
    function clearSubmitError() { submitError.classList.add('d-none'); }

    if (descInput) {
        descInput.addEventListener('input', function () {
            var hit = findBanned(descInput.value);
            if (hit) showDescError('Mot interdit détecté : « ' + hit + ' ». Merci de reformuler.');
            else clearDescError();
        });
    }

    // ===== Tile manager (images + videos) =====
    // Each tile represents either an EXISTING media (by id) or a NEW upload
    // (by index inside the <input> FileList). A single ordered array drives
    // the preview grid AND the hidden `image_order` / `video_order` manifest
    // that the server parses to apply the final ordering + deletions.
    function makeEditManager(opts) {
        var input       = opts.input;
        var grid        = opts.grid;
        var orderField  = opts.orderField;
        var kind        = opts.kind; // 'image' | 'video'
        var items       = []; // { type:'existing'|'new', id?, fileIdx?, url, name, file? }
        var dragSrc     = null;

        function serialize() {
            orderField.value = JSON.stringify(items.map(function (it) {
                return it.type === 'existing' ? ('existing:' + it.id) : ('new:' + it.fileIdx);
            }));
        }

        function syncInput() {
            // Rebuild the file input to contain only the "new" items, in the
            // ORDER they appear among new items (fileIdx is the index into
            // the FileList, which matches the server-side imageFiles[] order).
            try {
                var dt = new DataTransfer();
                var newItems = items.filter(function (it) { return it.type === 'new'; });
                newItems.forEach(function (it, i) {
                    dt.items.add(it.file);
                    it.fileIdx = i; // re-number to match their new input position
                });
                input.files = dt.files;
            } catch (_) {}
            serialize();
        }

        function render() {
            grid.innerHTML = '';
            items.forEach(function (it, idx) {
                var tile = document.createElement('div');
                tile.className = 'upload-preview-tile position-relative';
                tile.setAttribute('draggable', 'true');
                tile.style.cursor = 'grab';

                var media;
                if (kind === 'image') {
                    media = '<img src="' + it.url + '" style="width:100%;height:100%;object-fit:cover;border-radius:8px;">';
                } else {
                    media =
                        '<video src="' + it.url + '" muted playsinline style="width:100%;height:100%;object-fit:cover;border-radius:8px;"></video>' +
                        '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;">' +
                            '<i class="fas fa-play-circle text-white fs-3" style="text-shadow:0 2px 8px rgba(0,0,0,0.6);"></i>' +
                        '</div>';
                }

                tile.innerHTML =
                    media +
                    '<span class="badge bg-primary position-absolute" style="top:4px;left:4px;">' + (idx + 1) + '</span>' +
                    (it.type === 'new'
                        ? '<span class="badge bg-success position-absolute" style="bottom:28px;left:4px;">Nouveau</span>'
                        : '') +
                    '<button type="button" class="btn btn-sm btn-danger position-absolute tile-remove"' +
                        ' style="top:4px;right:4px;width:24px;height:24px;padding:0;line-height:1;border-radius:50%;"' +
                        ' aria-label="Retirer">&times;</button>' +
                    '<small class="d-block text-truncate mt-1">' + (it.name || '') + '</small>';

                tile.querySelector('.tile-remove').addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (it.type === 'new') {
                        try { URL.revokeObjectURL(it.url); } catch (_) {}
                    }
                    items.splice(idx, 1);
                    syncInput();
                    render();
                });

                tile.addEventListener('dragstart', function (e) {
                    dragSrc = idx;
                    tile.style.opacity = '0.4';
                    try { e.dataTransfer.effectAllowed = 'move'; } catch (_) {}
                });
                tile.addEventListener('dragend', function () {
                    tile.style.opacity = '';
                    dragSrc = null;
                });
                tile.addEventListener('dragover', function (e) {
                    e.preventDefault();
                    try { e.dataTransfer.dropEffect = 'move'; } catch (_) {}
                });
                tile.addEventListener('drop', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (dragSrc === null || dragSrc === idx) return;
                    var moved = items.splice(dragSrc, 1)[0];
                    items.splice(idx, 0, moved);
                    syncInput();
                    render();
                });

                grid.appendChild(tile);
            });
        }

        function seedExisting(list) {
            (list || []).forEach(function (e) {
                items.push({ type: 'existing', id: e.id, url: e.url, name: e.name });
            });
            syncInput();
            render();
        }

        function addNewFiles(fileList) {
            Array.from(fileList || []).forEach(function (f) {
                items.push({
                    type: 'new',
                    fileIdx: 0, // reassigned by syncInput
                    file: f,
                    url: URL.createObjectURL(f),
                    name: f.name || ''
                });
            });
            syncInput();
            render();
        }

        // Picking files in the <input> = APPEND to the grid.
        input.addEventListener('change', function () {
            var picked = Array.from(this.files || []);
            if (!picked.length) return;
            // Avoid double-add when syncInput() itself reassigns input.files:
            // if the file set exactly matches what we already hold, skip.
            var currentNewFiles = items.filter(function (it) { return it.type === 'new'; }).map(function (it) { return it.file; });
            if (picked.length === currentNewFiles.length &&
                picked.every(function (f, i) { return f === currentNewFiles[i]; })) {
                return;
            }
            // Determine which of `picked` are actually new (not already held).
            var genuinelyNew = picked.filter(function (f) { return currentNewFiles.indexOf(f) === -1; });
            if (genuinelyNew.length) {
                var dt = new DataTransfer();
                genuinelyNew.forEach(function (f) { dt.items.add(f); });
                addNewFiles(dt.files);
            }
        });

        return {
            seedExisting: seedExisting,
            addNewFiles: addNewFiles,
            count: function () { return items.length; }
        };
    }

    // ——— Seed from server-rendered JSON ———
    function parseJsonScript(id) {
        var el = document.getElementById(id);
        if (!el) return [];
        try { return JSON.parse(el.textContent || '[]'); } catch (_) { return []; }
    }
    var existingImages = parseJsonScript('edit-existing-images');
    var existingVideos = parseJsonScript('edit-existing-videos');

    var imageManager = makeEditManager({
        input:      form.querySelector('.edit-image-input'),
        grid:       form.querySelector('.edit-image-grid'),
        orderField: form.querySelector('.edit-image-order'),
        kind:       'image'
    });
    var videoManager = makeEditManager({
        input:      form.querySelector('.edit-video-input'),
        grid:       form.querySelector('.edit-video-grid'),
        orderField: form.querySelector('.edit-video-order'),
        kind:       'video'
    });

    imageManager.seedExisting(existingImages);
    videoManager.seedExisting(existingVideos);

    // Drag-and-drop files onto the video zone.
    var videoZone = form.querySelector('.edit-video-zone');
    if (videoZone) {
        ['dragenter', 'dragover'].forEach(function (evt) {
            videoZone.addEventListener(evt, function (e) { e.preventDefault(); videoZone.classList.add('drag-over'); });
        });
        ['dragleave', 'drop'].forEach(function (evt) {
            videoZone.addEventListener(evt, function (e) { e.preventDefault(); videoZone.classList.remove('drag-over'); });
        });
        videoZone.addEventListener('drop', function (e) {
            if (e.dataTransfer && e.dataTransfer.files.length) {
                videoManager.addNewFiles(e.dataTransfer.files);
            }
        });
    }

    // ===== Music preview =====
    var musicUrls   = {{ musicUrlsById|default({})|json_encode|raw }};
    var musicSelect = form.querySelector('.edit-music-select');
    var musicPrev   = form.querySelector('.edit-music-preview');
    if (musicSelect && musicPrev) {
        musicSelect.addEventListener('change', function () {
            var id = this.value;
            var url = id ? musicUrls[id] : null;
            if (url) { musicPrev.src = url; musicPrev.classList.remove('d-none'); }
            else     { musicPrev.pause(); musicPrev.removeAttribute('src'); musicPrev.classList.add('d-none'); }
        });
    }

    // ===== Submit validation =====
    form.addEventListener('submit', function (e) {
        clearSubmitError();

        var hit = descInput ? findBanned(descInput.value) : null;
        if (hit) {
            e.preventDefault();
            showDescError('Mot interdit détecté : « ' + hit + ' ». Merci de reformuler.');
            if (descInput) descInput.focus();
            return;
        }
        var descVal = descInput ? (descInput.value || '').trim() : '';
        if (!descVal) {
            e.preventDefault();
            showSubmitError('La description est obligatoire.');
            if (descInput) descInput.focus();
            return;
        }
        if (descVal.length < 5) {
            e.preventDefault();
            showSubmitError('La description doit contenir au moins 5 caractères.');
            if (descInput) descInput.focus();
            return;
        }
        if (imageManager.count() === 0 && videoManager.count() === 0) {
            e.preventDefault();
            showSubmitError('La publication doit contenir au moins une image ou une vidéo.');
            return;
        }
    });
})();
</script>
{% endblock %}
