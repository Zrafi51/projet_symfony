{% extends 'social/base.html.twig' %}

{% block title %}Chat avec {{ peer.username }} - Forum Voyage{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm chat-card">
            {# Header #}
            <div class="card-header bg-white d-flex align-items-center gap-3 py-3 border-bottom">
                <a href="{{ path('forum_messages') }}" class="btn btn-link text-muted p-0">
                    <i class="fas fa-arrow-left fs-5"></i>
                </a>
                <a href="{{ path('forum_user_profile', {username: peer.username}) }}"
                   class="d-flex align-items-center gap-2 text-decoration-none text-dark">
                    {% if peer.profilePhotoPath %}
                        <img src="{{ asset('uploads/profiles/' ~ peer.profilePhotoPath) }}"
                             class="rounded-circle" style="width:42px;height:42px;object-fit:cover;">
                    {% else %}
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center"
                             style="width:42px;height:42px;">
                            <span class="text-white fw-bold">{{ peer.username|first|upper }}</span>
                        </div>
                    {% endif %}
                    <div>
                        <strong class="d-block">{{ peer.username }}</strong>
                        <small class="text-muted">Voir le profil</small>
                    </div>
                </a>
            </div>

            {# Messages list #}
            <div class="card-body chat-thread" id="chatThread">
                {% if messages is empty %}
                    <div class="text-center text-muted py-5">
                        <i class="far fa-comment-dots fs-1"></i>
                        <p class="mt-3 mb-0">Lancez la conversation !</p>
                    </div>
                {% endif %}

                {# Pre-pass: find the index of the LAST message from me that has been
                   read by the peer. Instagram shows "Vu" only under that one. #}
                {% set lastReadMineIdx = -1 %}
                {% for m in messages %}
                    {% if m.senderUsername == app.user.username and m.isRead %}
                        {% set lastReadMineIdx = loop.index0 %}
                    {% endif %}
                {% endfor %}

                {% set prevDate = '' %}
                {% for m in messages %}
                    {% set curDate = m.createdAt|date('Y-m-d') %}
                    {% if curDate != prevDate %}
                        <div class="text-center my-3">
                            <small class="chat-date-sep px-3 py-1 rounded-pill text-muted bg-light">
                                {{ m.createdAt|date('d/m/Y') }}
                            </small>
                        </div>
                        {% set prevDate = curDate %}
                    {% endif %}
                    {% set mine = m.senderUsername == app.user.username %}
                    <div class="chat-bubble-row d-flex mb-2 flex-column {{ mine ? 'align-items-end' : 'align-items-start' }}">
                        {# Story-reply marker — shown ABOVE the bubble, like Instagram:
                           "Vous avez répondu à sa story" / "X a répondu à votre story"
                           + a small thumbnail of the referenced story (or a greyed
                           placeholder if the story has expired / been deleted). #}
                        {% if m.story is not null or (m.story is defined and m.story) %}
                            <small class="text-muted mb-1 small">
                                {{ mine ? 'Vous avez répondu à sa story' : m.senderUsername ~ ' a répondu à votre story' }}
                            </small>
                            <div class="story-reply-thumb mb-1">
                                {% if m.story %}
                                    {% if m.story.isImage %}
                                        <img src="{{ asset('uploads/stories/' ~ m.story.filename) }}" alt="story">
                                    {% else %}
                                        <video src="{{ asset('uploads/stories/' ~ m.story.filename) }}"
                                               muted playsinline preload="metadata"></video>
                                    {% endif %}
                                {% else %}
                                    {# Story expired / deleted — show a grey
                                       placeholder so the bubble still makes sense. #}
                                    <div class="story-reply-thumb-missing d-flex align-items-center justify-content-center">
                                        <i class="fas fa-circle-xmark text-muted"></i>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                        <div class="chat-bubble {{ mine ? 'chat-bubble-me' : 'chat-bubble-them' }}">
                            <div>{{ m.content|nl2br }}</div>
                            <small class="chat-bubble-time">{{ m.createdAt|date('H:i') }}</small>
                        </div>
                    </div>
                    {# "Vu" tick below the latest of MY messages that has been read. #}
                    {% if loop.index0 == lastReadMineIdx %}
                        <div class="chat-seen-indicator d-flex justify-content-end align-items-center mb-2 pe-2">
                            <small class="text-muted d-inline-flex align-items-center gap-1">
                                <i class="fas fa-check-double text-primary"></i>Vu
                            </small>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            {# Compose form — PHP-side validation (NotBlank + Length). #}
            <form method="post" class="card-footer bg-white border-top p-2" novalidate>
                <div class="input-group">
                    <input type="text" name="content" class="form-control form-control-lg border-0"
                           placeholder="Écrire un message..." autocomplete="off" autofocus>
                    <input type="hidden" name="_token" value="{{ csrf_token('send-msg') }}">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
/* Story-reply thumbnail above a DM bubble — small vertical rectangle, same
   9:16 vibe as the actual story, rounded + clipped so it feels attached
   to the bubble below it. */
.story-reply-thumb, .story-reply-thumb-missing {
    width: 90px;
    height: 140px;
    border-radius: 14px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.story-reply-thumb img, .story-reply-thumb video {
    width: 100%; height: 100%; object-fit: cover; display: block;
}
.story-reply-thumb-missing { background: #e9ecef; }
</style>
<script>
// Auto-scroll to the latest message on load.
document.addEventListener('DOMContentLoaded', function () {
    var t = document.getElementById('chatThread');
    if (t) t.scrollTop = t.scrollHeight;
});
</script>
{% endblock %}
